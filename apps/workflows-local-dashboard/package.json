  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "build:bundle": "vite build",
    "check-types": "tsc --noEmit",
    "dev": "vite build --watch",
    "dev:preview": "vite dev"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@uiw/react-codemirror": "^4.25.10",
    "@voyant-travel/ui": "workspace:^",
    "@voyant-travel/workflows": "workspace:^",
    "@voyant-travel/workflows-react": "workspace:^",
    "lucide-react": "^1.21.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
