{
  "name": "@voyant-travel/workflows-node-step-container",
  "version": "0.107.10",
  "description": "Reference Node container image for executing `runtime: \"node\"` steps. Deployed alongside the orchestrator as a Cloudflare Container.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "apps/workflows-node-step-container"
  },
  "homepage": "https://voyant.cloud/workflows",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist",
    "src",
    "Dockerfile",
    "LICENSE",
    "README.md",
    "NOTICE"
  ],
  "bin": {
    "voyant-workflows-node-step-container": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run clean && pnpm run build",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@voyant-travel/workflows": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/server.d.ts",
        "import": "./dist/server.js"
      }
    },
    "main": "./dist/server.js",
    "types": "./dist/server.d.ts",
    "bin": {
      "voyant-workflows-node-step-container": "./dist/server.js"
    }
  }
}
