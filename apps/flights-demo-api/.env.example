# Standalone Postgres for the demo flight service. Keep separate from the
# operator's main DB — this is purely demo state. The bundled
# `docker-compose.yml` exposes Postgres on host port 5435 with user, password,
# and database all set to the obvious demo defaults (see docker-compose.yml).
# Just `docker compose up -d`; the URL below matches that local container.
FLIGHTS_DEMO_DATABASE_URL="postgresql://postgres:demo@localhost:5435/flights_demo"

# HTTP port the service listens on (default 3320).
PORT=3320
