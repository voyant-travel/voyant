{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "voyant-bookings-traveler-dialog",
  "title": "Traveler Dialog",
  "description": "Create/edit traveler dialog wired to bookings-react traveler mutations.",
  "dependencies": ["@voyantjs/bookings-react", "lucide-react"],
  "registryDependencies": ["dialog", "input", "label", "textarea"],
  "files": [
    {
      "path": "registry/bookings/traveler-dialog.tsx",
      "content": "export { TravelerDialog, type TravelerDialogProps } from \"@voyantjs/bookings-ui\"\n",
      "type": "registry:component",
      "target": "components/voyant/bookings/traveler-dialog.tsx"
    }
  ],
  "type": "registry:component"
}
