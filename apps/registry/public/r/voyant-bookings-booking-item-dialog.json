{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "voyant-bookings-booking-item-dialog",
  "title": "Booking Item Dialog",
  "description": "Create/edit booking item dialog wired to bookings-react item mutations.",
  "dependencies": ["@voyantjs/bookings-react", "lucide-react"],
  "registryDependencies": ["dialog", "input", "label", "select", "textarea"],
  "files": [
    {
      "path": "registry/bookings/booking-item-dialog.tsx",
      "content": "export { BookingItemDialog, type BookingItemDialogProps } from \"@voyantjs/bookings-ui\"\n",
      "type": "registry:component",
      "target": "components/voyant/bookings/booking-item-dialog.tsx"
    }
  ],
  "type": "registry:component"
}
