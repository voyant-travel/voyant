# Standalone Postgres for the catalog demo service. Keep separate from the
# operator's main DB — this is purely demo state. The bundled
# `docker-compose.yml` exposes Postgres on host port 5437 with user, password,
# and database all set to obvious demo defaults (see docker-compose.yml).
# Just `docker compose up -d`, fill in the URL below to match, and you're done.
CATALOG_DEMO_DATABASE_URL="postgresql://user:password@host:port/database"

# HTTP port the service listens on (default 3330).
PORT=3330

# Optional: when "true", the service auto-seeds default inventory rows on
# startup if the inventory table is empty. Useful in dev; set to "false"
# (or omit) when running against a hand-curated dataset.
AUTO_SEED=true
