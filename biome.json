{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "warn"
      },
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/.voyant",
      "!**/.next",
      "!**/.wrangler",
      "!**/.vinxi",
      "!**/.output",
      "!**/.turbo",
      "!**/.agents",
      "!**/.claude",
      "!**/docs/open-travel",
      "!**/*.gen.ts",
      "!**/*.generated.ts",
      "!**/migrations",
      "!apps/workflows-node-step-container/bundle.mjs",
      "!apps/workflows-selfhost-cloudflare-worker/src/bundle.mjs",
      "!apps/workflows-tenant-worker/src/bundle.mjs",
      "!packages/admin/src/styles.css",
      "!packages/ui/src/styles.css",
      "!packages/ui/src/styles/globals.css",
      "!packages/*-ui/src/styles.css",
      "!packages/*-react/src/styles.css",
      "!packages/commerce-react/src/*/styles.css",
      "!templates/operator/src/components/ui",
      "!templates/operator/src/lib/async-utils.ts",
      "!templates/operator/src/styles.css"
    ]
  }
}
