{
  "name": "@voyant-travel/admin-react",
  "version": "0.123.3",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/admin-react"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./provider": "./src/provider.tsx",
    "./hooks": "./src/hooks.ts",
    "./query-keys": "./src/query-keys.ts",
    "./user": "./src/user.tsx",
    "./user-bindings": "./src/user-bindings.tsx"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^19.0.0"
  },
  "dependencies": {
    "@voyant-travel/admin-client": "workspace:^"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./provider": {
        "types": "./dist/provider.d.ts",
        "import": "./dist/provider.js",
        "default": "./dist/provider.js"
      },
      "./hooks": {
        "types": "./dist/hooks.d.ts",
        "import": "./dist/hooks.js",
        "default": "./dist/hooks.js"
      },
      "./query-keys": {
        "types": "./dist/query-keys.d.ts",
        "import": "./dist/query-keys.js",
        "default": "./dist/query-keys.js"
      },
      "./user": {
        "types": "./dist/user.d.ts",
        "import": "./dist/user.js",
        "default": "./dist/user.js"
      },
      "./user-bindings": {
        "types": "./dist/user-bindings.d.ts",
        "import": "./dist/user-bindings.js",
        "default": "./dist/user-bindings.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  }
}
