{
  "name": "@voyant-travel/plugin-sanity-cms",
  "version": "0.105.23",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./plugin": "./src/plugin.ts",
    "./types": "./src/types.ts",
    "./voyant": "./src/voyant.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/utils": "workspace:^",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./client": {
        "types": "./dist/client.d.ts",
        "import": "./dist/client.js",
        "default": "./dist/client.js"
      },
      "./plugin": {
        "types": "./dist/plugin.d.ts",
        "import": "./dist/plugin.js",
        "default": "./dist/plugin.js"
      },
      "./types": {
        "types": "./dist/types.d.ts",
        "import": "./dist/types.js",
        "default": "./dist/types.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/plugins/sanity-cms"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "plugin",
    "manifest": "./voyant"
  }
}
