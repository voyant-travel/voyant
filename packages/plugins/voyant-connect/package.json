{
  "name": "@voyant-travel/plugin-voyant-connect",
  "version": "0.1.1",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@voyant-travel/catalog": "workspace:^",
    "@voyant-travel/connect-adapter": "0.3.0",
    "@voyant-travel/connect-cruises": "0.4.0",
    "@voyant-travel/connect-sdk": "0.9.0",
    "@voyant-travel/cruises": "workspace:^",
    "@voyant-travel/data-sdk": "^0.5.0"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/plugins/voyant-connect"
  }
}
