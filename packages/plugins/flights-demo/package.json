{
  "name": "@voyant-travel/plugin-flights-demo",
  "version": "0.21.0",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/plugins/flights-demo"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./voyant": "./src/voyant.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@voyant-travel/flights": "workspace:^"
  },
  "dependencies": {
    "@voyant-travel/core": "workspace:^"
  },
  "devDependencies": {
    "@voyant-travel/flights": "workspace:^",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "plugin",
    "manifest": "./voyant"
  }
}
