  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/cruises"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "runtime": {
      "entry": "./runtime-contributor",
      "export": "createCruisesRuntimePortContribution"
    },
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    },
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/db"
