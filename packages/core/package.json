{
  "name": "@voyant-travel/core",
  "version": "0.123.0",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./env": "./src/env.ts",
    "./module": "./src/module.ts",
    "./hooks": "./src/hooks.ts",
