{
  "name": "@voyant-travel/workflow-runs",
  "version": "0.122.8",
  "description": "Workflow run recording, admin routes, and rerun/resume dispatch primitives for Voyant operator apps.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./service": "./src/service.ts",
    "./routes": "./src/routes.ts",
    "./api-runtime": "./src/api-runtime.ts",
    "./recorder": "./src/recorder.ts",
    "./runtime-port": "./src/runtime-port.ts",
    "./tools": "./src/mcp-runtime.ts",
    "./scheduled-workflow": "./src/scheduled-workflow.ts",
    "./workflows": "./src/workflows.ts",
    "./runtime-contributor": "./src/runtime-contributor.ts",
    "./voyant": "./src/voyant.ts",
    "./openapi/admin": "./openapi/admin/workflow-runs.json"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "runtime": {
      "entry": "./runtime-contributor",
      "export": "createWorkflowRunsRuntimePortContribution"
    },
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    },
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/db"
    ]
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=workflow_runs_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/tools": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "@voyant-travel/workflows": "workspace:^",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "@voyant-travel/workflows-orchestrator": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "openapi",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./service": {
        "types": "./dist/service.d.ts",
        "import": "./dist/service.js",
        "default": "./dist/service.js"
      },
      "./routes": {
        "types": "./dist/routes.d.ts",
        "import": "./dist/routes.js",
        "default": "./dist/routes.js"
      },
      "./api-runtime": {
        "types": "./dist/api-runtime.d.ts",
        "import": "./dist/api-runtime.js",
        "default": "./dist/api-runtime.js"
      },
      "./recorder": {
        "types": "./dist/recorder.d.ts",
        "import": "./dist/recorder.js",
        "default": "./dist/recorder.js"
      },
      "./runtime-port": {
        "types": "./dist/runtime-port.d.ts",
        "import": "./dist/runtime-port.js",
        "default": "./dist/runtime-port.js"
      },
      "./tools": {
        "types": "./dist/mcp-runtime.d.ts",
        "import": "./dist/mcp-runtime.js",
        "default": "./dist/mcp-runtime.js"
      },
      "./scheduled-workflow": {
        "types": "./dist/scheduled-workflow.d.ts",
        "import": "./dist/scheduled-workflow.js",
        "default": "./dist/scheduled-workflow.js"
      },
      "./workflows": {
        "types": "./dist/workflows.d.ts",
        "import": "./dist/workflows.js",
        "default": "./dist/workflows.js"
      },
      "./runtime-contributor": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      },
      "./openapi/admin": "./openapi/admin/workflow-runs.json"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/workflow-runs"
  }
}
