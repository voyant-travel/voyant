{
  "name": "@voyantjs/markets-react",
  "version": "0.107.1",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/markets-react"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./provider": "./src/provider.tsx",
    "./hooks": "./src/hooks/index.ts",
    "./client": "./src/client.ts",
    "./query-keys": "./src/query-keys.ts",
    "./ui": "./src/ui.ts",
    "./styles.css": "./src/styles.css",
    "./i18n": "./src/i18n/index.ts",
    "./i18n/en": "./src/i18n/en.ts",
    "./i18n/ro": "./src/i18n/ro.ts",
    "./components/*": "./src/components/*.tsx"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-table": "^8.0.0",
    "@voyantjs/markets": "workspace:^",
    "@voyantjs/ui": "workspace:^",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-table": {
      "optional": true
    },
    "@voyantjs/ui": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    }
  },
  "dependencies": {
    "@voyantjs/i18n": "workspace:^",
    "@voyantjs/react": "workspace:^"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-table": "^8.21.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@voyantjs/i18n": "workspace:^",
    "@voyantjs/markets": "workspace:^",
    "@voyantjs/react": "workspace:^",
    "@voyantjs/ui": "workspace:^",
    "@voyantjs/voyant-typescript-config": "workspace:^",
    "lucide-react": "^0.475.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.60.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src/styles.css"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./provider": {
        "types": "./dist/provider.d.ts",
        "import": "./dist/provider.js",
        "default": "./dist/provider.js"
      },
      "./hooks": {
        "types": "./dist/hooks/index.d.ts",
        "import": "./dist/hooks/index.js",
        "default": "./dist/hooks/index.js"
      },
      "./client": {
        "types": "./dist/client.d.ts",
        "import": "./dist/client.js",
        "default": "./dist/client.js"
      },
      "./query-keys": {
        "types": "./dist/query-keys.d.ts",
        "import": "./dist/query-keys.js",
        "default": "./dist/query-keys.js"
      },
      "./ui": {
        "types": "./dist/ui.d.ts",
        "import": "./dist/ui.js",
        "default": "./dist/ui.js"
      },
      "./styles.css": {
        "default": "./src/styles.css"
      },
      "./i18n": {
        "types": "./dist/i18n/index.d.ts",
        "import": "./dist/i18n/index.js",
        "default": "./dist/i18n/index.js"
      },
      "./i18n/en": {
        "types": "./dist/i18n/en.d.ts",
        "import": "./dist/i18n/en.js",
        "default": "./dist/i18n/en.js"
      },
      "./i18n/ro": {
        "types": "./dist/i18n/ro.d.ts",
        "import": "./dist/i18n/ro.js",
        "default": "./dist/i18n/ro.js"
      },
      "./components/*": {
        "types": "./dist/components/*.d.ts",
        "import": "./dist/components/*.js",
        "default": "./dist/components/*.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  }
}
