{
  "name": "@voyant-travel/finance-node",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/runtime-contributor.ts",
    "./runtime-contributor": "./src/runtime-contributor.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      },
      "./runtime-contributor": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      }
    },
    "main": "./dist/runtime-contributor.js",
    "types": "./dist/runtime-contributor.d.ts"
  },
  "dependencies": {
    "@voyant-travel/accommodations": "workspace:^",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/cruises": "workspace:^",
    "@voyant-travel/distribution": "workspace:^",
    "@voyant-travel/finance": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/inventory": "workspace:^",
    "@voyant-travel/notifications": "workspace:^",
    "@voyant-travel/operator-settings": "workspace:^",
    "@voyant-travel/plugin-netopia": "^0.105.20",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/finance-node"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "library",
    "runtime": {
      "entry": "./runtime-contributor",
      "export": "createFinanceNodeRuntimePortContribution"
    },
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    }
  }
}
