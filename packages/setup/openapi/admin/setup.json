{
  "info": {
    "title": "Setup Admin API",
    "version": "1.0.0"
  },
  "components": {
    "schemas": {},
    "parameters": {}
  },
  "paths": {
    "/v1/admin/setup": {
      "get": {
        "operationId": "getSetupState",
        "x-voyant-api-id": "@voyant-travel/setup#api.admin",
        "responses": {
          "200": {
            "description": "Setup state",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "nullable": true,
                      "properties": {
                        "startedAt": {
                          "type": "string",
                          "format": "date-time"
                        },
                        "firstRunOpenedAt": {
                          "type": "string",
                          "nullable": true,
                          "format": "date-time"
                        },
                        "steps": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "stepId": {
                                "type": "string",
                                "minLength": 1,
                                "maxLength": 200
                              },
                              "firstSeenAt": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "completedAt": {
                                "type": "string",
                                "nullable": true,
                                "format": "date-time"
                              },
                              "skippedAt": {
                                "type": "string",
                                "nullable": true,
                                "format": "date-time"
                              }
                            },
                            "required": ["stepId", "firstSeenAt", "completedAt", "skippedAt"]
                          }
                        },
                        "prefill": {
                          "type": "object",
                          "additionalProperties": {
                            "nullable": true
                          }
                        }
                      },
                      "required": ["startedAt", "firstRunOpenedAt", "steps", "prefill"]
                    }
                  },
                  "required": ["data"]
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/admin/setup/initialize": {
      "post": {
        "operationId": "initializeSetup",
        "x-voyant-api-id": "@voyant-travel/setup#api.admin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "stepIds": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 200
                    },
                    "maxItems": 100
                  },
                  "fresh": {
                    "type": "boolean"
                  }
                },
                "required": ["stepIds", "fresh"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Initialized setup state",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "startedAt": {
                          "type": "string",
                          "format": "date-time"
                        },
                        "firstRunOpenedAt": {
                          "type": "string",
                          "nullable": true,
                          "format": "date-time"
                        },
                        "steps": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "stepId": {
                                "type": "string",
                                "minLength": 1,
                                "maxLength": 200
                              },
                              "firstSeenAt": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "completedAt": {
                                "type": "string",
                                "nullable": true,
                                "format": "date-time"
                              },
                              "skippedAt": {
                                "type": "string",
                                "nullable": true,
                                "format": "date-time"
                              }
                            },
                            "required": ["stepId", "firstSeenAt", "completedAt", "skippedAt"]
                          }
                        },
                        "prefill": {
                          "type": "object",
                          "additionalProperties": {
                            "nullable": true
                          }
                        },
                        "shouldRedirect": {
                          "type": "boolean"
                        }
                      },
                      "required": [
                        "startedAt",
                        "firstRunOpenedAt",
                        "steps",
                        "prefill",
                        "shouldRedirect"
                      ]
                    }
                  },
                  "required": ["data"]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/admin/setup/steps/{stepId}/complete": {
      "post": {
        "operationId": "completeSetupStep",
        "x-voyant-api-id": "@voyant-travel/setup#api.admin",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "required": true,
            "name": "stepId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Completed setup step",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "stepId": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 200
                        },
                        "firstSeenAt": {
                          "type": "string",
                          "format": "date-time"
                        },
                        "completedAt": {
                          "type": "string",
                          "nullable": true,
                          "format": "date-time"
                        },
                        "skippedAt": {
                          "type": "string",
                          "nullable": true,
                          "format": "date-time"
                        }
                      },
                      "required": ["stepId", "firstSeenAt", "completedAt", "skippedAt"]
                    }
                  },
                  "required": ["data"]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/admin/setup/steps/{stepId}/skip": {
      "post": {
        "operationId": "skipSetupStep",
        "x-voyant-api-id": "@voyant-travel/setup#api.admin",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "required": true,
            "name": "stepId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Skipped setup step",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "stepId": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 200
                        },
                        "firstSeenAt": {
                          "type": "string",
                          "format": "date-time"
                        },
                        "completedAt": {
                          "type": "string",
                          "nullable": true,
                          "format": "date-time"
                        },
                        "skippedAt": {
                          "type": "string",
                          "nullable": true,
                          "format": "date-time"
                        }
                      },
                      "required": ["stepId", "firstSeenAt", "completedAt", "skippedAt"]
                    }
                  },
                  "required": ["data"]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
