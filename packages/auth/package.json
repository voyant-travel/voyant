{
  "name": "@voyant-travel/auth",
  "version": "0.124.2",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/auth"
  },
  "description": "Auth package for the workspace",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./edge": {
      "types": "./src/edge.ts",
      "default": "./src/edge.ts"
    },
    "./backend": {
      "types": "./src/backend.ts",
      "default": "./src/backend.ts"
    },
    "./operator-node-runtime": {
      "types": "./src/operator-node-runtime.ts",
      "default": "./src/operator-node-runtime.ts"
    },
    "./cloud-broker": {
      "types": "./src/cloud-broker.ts",
      "default": "./src/cloud-broker.ts"
    },
    "./cloud-admin-session": {
      "types": "./src/cloud-admin-session-public.ts",
      "default": "./src/cloud-admin-session.ts"
    },
    "./workspace": {
      "types": "./src/workspace.ts",
      "default": "./src/workspace.ts"
    },
    "./permissions": {
      "types": "./src/permissions.ts",
      "default": "./src/permissions.ts"
    },
    "./identity-access-runtime-port": {
      "types": "./src/identity-access-runtime-port.ts",
      "default": "./src/identity-access-runtime-port.ts"
    },
    "./identity-access-graph-runtime": {
      "types": "./src/identity-access-graph-runtime.ts",
      "default": "./src/identity-access-graph-runtime.ts"
    },
    "./runtime-contributor": {
      "types": "./src/runtime-contributor.ts",
      "default": "./src/runtime-contributor.ts"
    },
    "./voyant": {
      "types": "./src/voyant.ts",
      "default": "./src/voyant.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./server": {
        "types": "./dist/server.d.ts",
        "import": "./dist/server.js",
        "default": "./dist/server.js"
      },
      "./edge": {
        "types": "./dist/edge.d.ts",
        "import": "./dist/edge.js",
        "default": "./dist/edge.js"
      },
      "./backend": {
        "types": "./dist/backend.d.ts",
        "import": "./dist/backend.js",
        "default": "./dist/backend.js"
      },
      "./operator-node-runtime": {
        "types": "./dist/operator-node-runtime.d.ts",
        "import": "./dist/operator-node-runtime.js",
        "default": "./dist/operator-node-runtime.js"
      },
      "./cloud-broker": {
        "types": "./dist/cloud-broker.d.ts",
        "import": "./dist/cloud-broker.js",
        "default": "./dist/cloud-broker.js"
      },
      "./cloud-admin-session": {
        "types": "./dist/cloud-admin-session-public.d.ts",
        "import": "./dist/cloud-admin-session.js",
        "default": "./dist/cloud-admin-session.js"
      },
      "./workspace": {
        "types": "./dist/workspace.d.ts",
        "import": "./dist/workspace.js",
        "default": "./dist/workspace.js"
      },
      "./permissions": {
        "types": "./dist/permissions.d.ts",
        "import": "./dist/permissions.js",
        "default": "./dist/permissions.js"
      },
      "./identity-access-runtime-port": {
        "types": "./dist/identity-access-runtime-port.d.ts",
        "import": "./dist/identity-access-runtime-port.js",
        "default": "./dist/identity-access-runtime-port.js"
      },
      "./identity-access-graph-runtime": {
        "types": "./dist/identity-access-graph-runtime.d.ts",
        "import": "./dist/identity-access-graph-runtime.js",
        "default": "./dist/identity-access-graph-runtime.js"
      },
      "./runtime-contributor": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "biome check src/",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@better-auth/api-key": "1.6.23",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "@voyant-travel/utils": "workspace:^",
    "better-auth": "1.6.23",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "typescript": "catalog:"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "runtime": {
      "entry": "./runtime-contributor",
      "export": "createAuthRuntimePortContribution"
    },
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    },
    "requiresSchemas": [
      "@voyant-travel/db"
    ]
  }
}
