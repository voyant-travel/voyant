{
  "name": "@voyant-travel/auth",
  "version": "0.120.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/auth"
  },
  "description": "Auth package for the workspace",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./edge": {
      "types": "./src/edge.ts",
      "default": "./src/edge.ts"
    },
    "./backend": {
      "types": "./src/backend.ts",
      "default": "./src/backend.ts"
    },
    "./cloud-broker": {
      "types": "./src/cloud-broker.ts",
      "default": "./src/cloud-broker.ts"
    },
    "./cloud-admin-session": {
      "types": "./src/cloud-admin-session-public.ts",
      "default": "./src/cloud-admin-session.ts"
    },
    "./workspace": {
      "types": "./src/workspace.ts",
      "default": "./src/workspace.ts"
    },
    "./permissions": {
      "types": "./src/permissions.ts",
      "default": "./src/permissions.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./server": {
        "types": "./dist/server.d.ts",
        "import": "./dist/server.js",
        "default": "./dist/server.js"
      },
      "./edge": {
        "types": "./dist/edge.d.ts",
        "import": "./dist/edge.js",
        "default": "./dist/edge.js"
      },
      "./backend": {
        "types": "./dist/backend.d.ts",
        "import": "./dist/backend.js",
        "default": "./dist/backend.js"
      },
      "./cloud-broker": {
        "types": "./dist/cloud-broker.d.ts",
        "import": "./dist/cloud-broker.js",
        "default": "./dist/cloud-broker.js"
      },
      "./cloud-admin-session": {
        "types": "./dist/cloud-admin-session-public.d.ts",
        "import": "./dist/cloud-admin-session.js",
        "default": "./dist/cloud-admin-session.js"
      },
      "./workspace": {
        "types": "./dist/workspace.d.ts",
        "import": "./dist/workspace.js",
        "default": "./dist/workspace.js"
      },
      "./permissions": {
        "types": "./dist/permissions.d.ts",
        "import": "./dist/permissions.js",
        "default": "./dist/permissions.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "biome check src/",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@better-auth/api-key": "1.6.23",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "@voyant-travel/utils": "workspace:^",
    "better-auth": "1.6.23",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "typescript": "catalog:"
  }
}
