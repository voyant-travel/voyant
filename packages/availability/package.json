{
  "name": "@voyantjs/availability",
  "version": "0.116.3",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./validation": "./src/validation.ts",
    "./routes": "./src/routes.ts",
    "./rrule": "./src/rrule.ts",
    "./service-holds": "./src/service-holds.ts",
    "./service-catalog-plane-departures": "./src/service-catalog-plane-departures.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@voyantjs/operations": "workspace:^"
  },
  "devDependencies": {
    "@voyantjs/voyant-typescript-config": "workspace:^",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./validation": {
        "types": "./dist/validation.d.ts",
        "import": "./dist/validation.js",
        "default": "./dist/validation.js"
      },
      "./routes": {
        "types": "./dist/routes.d.ts",
        "import": "./dist/routes.js",
        "default": "./dist/routes.js"
      },
      "./rrule": {
        "types": "./dist/rrule.d.ts",
        "import": "./dist/rrule.js",
        "default": "./dist/rrule.js"
      },
      "./service-holds": {
        "types": "./dist/service-holds.d.ts",
        "import": "./dist/service-holds.js",
        "default": "./dist/service-holds.js"
      },
      "./service-catalog-plane-departures": {
        "types": "./dist/service-catalog-plane-departures.d.ts",
        "import": "./dist/service-catalog-plane-departures.js",
        "default": "./dist/service-catalog-plane-departures.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/availability"
  },
  "voyant": {
    "schema": "./schema",
    "requiresSchemas": [
      "@voyantjs/db"
    ]
  }
}
