{
  "name": "@voyant-travel/quotes-node",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/runtime-contributor.ts",
    "./runtime-contributor": "./src/runtime-contributor.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      },
      "./runtime-contributor": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      }
    },
    "main": "./dist/runtime-contributor.js",
    "types": "./dist/runtime-contributor.d.ts"
  },
  "dependencies": {
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/operator-settings": "workspace:^",
    "@voyant-travel/quotes": "workspace:^",
    "@voyant-travel/relationships": "workspace:^",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/quotes-node"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "library",
    "runtime": {
      "entry": "./runtime-contributor",
      "export": "createQuotesNodeRuntimePortContribution"
    },
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": ["node"],
      "modes": ["local", "managed-cloud", "self-hosted"]
    }
  }
}
