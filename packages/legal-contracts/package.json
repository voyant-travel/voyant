{
  "name": "@voyant-travel/legal-contracts",
  "version": "0.106.12",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./contracts/validation": "./src/contracts/validation.ts",
    "./policies/validation": "./src/policies/validation.ts",
    "./targets/validation": "./src/targets/validation.ts",
    "./terms/validation": "./src/terms/validation.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./contracts/validation": {
        "types": "./dist/contracts/validation.d.ts",
        "import": "./dist/contracts/validation.js",
        "default": "./dist/contracts/validation.js"
      },
      "./policies/validation": {
        "types": "./dist/policies/validation.d.ts",
        "import": "./dist/policies/validation.js",
        "default": "./dist/policies/validation.js"
      },
      "./targets/validation": {
        "types": "./dist/targets/validation.d.ts",
        "import": "./dist/targets/validation.js",
        "default": "./dist/targets/validation.js"
      },
      "./terms/validation": {
        "types": "./dist/terms/validation.d.ts",
        "import": "./dist/terms/validation.js",
        "default": "./dist/terms/validation.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "dependencies": {
    "@voyant-travel/schema-kit": "workspace:^",
    "@voyant-travel/templating": "workspace:^",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/legal-contracts"
  }
}
