{
  "name": "@voyant-travel/webhook-delivery",
  "version": "0.5.3",
  "description": "Durable, policy-aware outbound webhook delivery for Voyant Node deployments.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./admin-contracts": "./src/admin-contracts.ts",
    "./api-runtime": "./src/api-runtime.ts",
    "./voyant": "./src/voyant.ts",
    "./postgres": "./src/postgres-store.ts",
    "./openapi/admin": "./openapi/admin/operator-webhooks.json"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "compatibleWith": {
      "framework": ">=0.44.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    },
    "requiresSchemas": [
      "@voyant-travel/db"
    ]
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/ tests/ scripts/",
    "test": "vitest run",
    "generate:openapi": "tsx scripts/generate-openapi.ts",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm --workspace-concurrency=1 --filter @voyant-travel/webhook-delivery... run build"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "openapi"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./admin-contracts": {
        "types": "./dist/admin-contracts.d.ts",
        "import": "./dist/admin-contracts.js",
        "default": "./dist/admin-contracts.js"
      },
      "./api-runtime": {
        "types": "./dist/api-runtime.d.ts",
        "import": "./dist/api-runtime.js",
        "default": "./dist/api-runtime.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      },
      "./postgres": {
        "types": "./dist/postgres-store.d.ts",
        "import": "./dist/postgres-store.js",
        "default": "./dist/postgres-store.js"
      },
      "./openapi/admin": "./openapi/admin/operator-webhooks.json"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/webhook-delivery"
  }
}
