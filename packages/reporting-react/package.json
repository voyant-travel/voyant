{
  "name": "@voyant-travel/reporting-react",
  "version": "0.4.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/reporting-react"
  },
  "type": "module",
  "sideEffects": [
    "./src/styles.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./admin": "./src/admin/index.tsx",
    "./grid": "./src/grid/voyant-grid.tsx",
    "./layout": "./src/layout/grid-model.ts",
    "./hooks": "./src/hooks/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@voyant-travel/admin": "workspace:^",
    "@voyant-travel/ui": "workspace:^",
    "lucide-react": "^0.475.0 || ^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "@voyant-travel/admin": {
      "optional": true
    },
    "@voyant-travel/ui": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "recharts": {
      "optional": true
    }
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "@voyant-travel/react": "workspace:^",
    "@voyant-travel/reporting-contracts": "workspace:^",
    "html-to-image": "^1.11.11",
    "motion": "^12.42.2",
    "pdf-lib": "^1.17.1",
    "react-grid-layout": "^1.5.2",
    "react-resizable-panels": "^3.0.3"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^1.3.5",
    "@voyant-travel/admin": "workspace:^",
    "@voyant-travel/ui": "workspace:^",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "3.9.2",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "files": [
    "dist",
    "src/styles.css"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./admin": {
        "types": "./dist/admin/index.d.ts",
        "import": "./dist/admin/index.js",
        "default": "./dist/admin/index.js"
      },
      "./grid": {
        "types": "./dist/grid/voyant-grid.d.ts",
        "import": "./dist/grid/voyant-grid.js"
      },
      "./layout": {
        "types": "./dist/layout/grid-model.d.ts",
        "import": "./dist/layout/grid-model.js"
      },
      "./hooks": {
        "types": "./dist/hooks/index.d.ts",
        "import": "./dist/hooks/index.js"
      },
      "./styles.css": {
        "default": "./src/styles.css"
      }
    }
  }
}
