{
  "name": "@voyant-travel/reporting-react",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/reporting-react"
  },
  "type": "module",
  "sideEffects": [
    "./src/styles.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./grid": "./src/grid/voyant-grid.tsx",
    "./layout": "./src/layout/grid-model.ts",
    "./hooks": "./src/hooks/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "motion": "^12.42.2",
    "react-grid-layout": "^1.5.2",
    "react-resizable-panels": "^3.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^1.3.5",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src/styles.css"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./grid": {
        "types": "./dist/grid/voyant-grid.d.ts",
        "import": "./dist/grid/voyant-grid.js"
      },
      "./layout": {
        "types": "./dist/layout/grid-model.d.ts",
        "import": "./dist/layout/grid-model.js"
      },
      "./hooks": {
        "types": "./dist/hooks/index.d.ts",
        "import": "./dist/hooks/index.js"
      },
      "./styles.css": {
        "default": "./src/styles.css"
      }
    }
  }
}
