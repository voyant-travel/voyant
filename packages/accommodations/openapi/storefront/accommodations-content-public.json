                            "sourceLocale": {
                              "type": ["string", "null"],
                              "minLength": 1
                            },
                            "servedLocale": {
                              "type": "string",
                              "minLength": 1
                            },
                            "matchKind": {
                              "type": "string",
                              "enum": ["exact", "mixed", "overlay-only"]
