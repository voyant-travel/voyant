          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "default": "en-GB"
            },
            "required": false,
            "name": "locale",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": ["customer", "partner"],
