                              "minLength": 1
                            },
                            "name": {
                              "type": ["string", "null"]
                            },
                            "description": {
                              "type": ["string", "null"]
                            },
                            "hero_image_url": {
                              "type": ["string", "null"]
                            },
                            "gallery": {
                              "type": "array",
                              "items": {
                                "type": "string",
                                "format": "uri"
                              }
                            },
                            "highlights": {
                              "type": "array",
                              "items": {
                                "type": "string",
                                "minLength": 1
                              }
                            },
                            "amenities": {
                              "type": "array",
                              "items": {
                                "type": "string",
                                "minLength": 1
                              }
                            },
                            "star_rating": {
                              "type": ["integer", "null"],
                              "minimum": 0,
                              "maximum": 10
                            },
                            "brand": {
                              "type": ["string", "null"]
                            },
                            "country": {
                              "type": ["string", "null"]
                            },
                            "city": {
                              "type": ["string", "null"]
                            },
                            "address": {
                              "type": ["string", "null"]
                            },
                            "postal_code": {
                              "type": ["string", "null"]
                            },
                            "latitude": {
                              "type": ["number", "null"]
                            },
                            "longitude": {
                              "type": ["number", "null"]
                            },
                            "check_in_time": {
                              "type": ["string", "null"]
                            },
                            "check_out_time": {
                              "type": ["string", "null"]
                            }
                          },
                          "required": ["id"],
                          "additionalProperties": false
                        }
                      },
                      "required": ["subject", "locale", "content"]
                    }
                  },
                  "required": ["data"]
                }
              }
            }
          },
          "404": {
            "description": "Accommodation property was not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "detail": {
                      "type": "string"
                    },
                    "currentVersion": {
                      "type": ["integer", "null"]
                    }
                  },
                  "required": ["error"]
                }
              }
            }
          }
        }
      }
