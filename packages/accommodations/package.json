{
  "name": "@voyant-travel/accommodations",
  "version": "0.113.0",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./linkables": "./src/linkables.ts",
    "./standard-links": "./src/standard-links.ts",
    "./content-shape": "./src/content-shape.ts",
    "./service-content": "./src/service-content.ts",
    "./service-content-synthesizer": "./src/service-content-synthesizer.ts",
    "./booking-overview-enricher": "./src/booking-overview-enricher.ts",
    "./service-owned-stays": "./src/service-owned-stays.ts",
    "./catalog-policy": "./src/catalog-policy.ts",
    "./service-catalog-plane": "./src/service-catalog-plane.ts",
    "./draft-shape": "./src/draft-shape.ts",
    "./booking-engine": "./src/booking-engine/index.ts",
    "./booking-engine/runtime": "./src/booking-engine/runtime.ts",
    "./routes-content": "./src/routes-content.ts",
    "./graph-runtime": "./src/graph-runtime.ts",
    "./runtime-contributor": "./src/runtime-contributor.ts",
    "./payment-policy-runtime": "./src/payment-policy-runtime.ts",
    "./voyant": "./src/voyant.ts",
    "./openapi/admin": "./openapi/admin/accommodations.json",
    "./openapi/storefront": "./openapi/storefront/accommodations-content-public.json",
    "./catalog-runtime-extension": "./src/catalog-runtime-extension.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=accommodations_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/accommodations-contracts": "workspace:^",
    "@voyant-travel/allotments": "workspace:^",
    "@voyant-travel/bookings": "workspace:^",
    "@voyant-travel/catalog": "workspace:^",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/finance": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/operations": "workspace:^",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@voyant-travel/distribution": "workspace:^",
    "@voyant-travel/mice": "workspace:^"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "openapi",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./linkables": {
        "types": "./dist/linkables.d.ts",
        "import": "./dist/linkables.js",
        "default": "./dist/linkables.js"
      },
      "./standard-links": {
        "types": "./dist/standard-links.d.ts",
        "import": "./dist/standard-links.js",
        "default": "./dist/standard-links.js"
      },
      "./content-shape": {
        "types": "./dist/content-shape.d.ts",
        "import": "./dist/content-shape.js",
        "default": "./dist/content-shape.js"
      },
      "./service-content": {
        "types": "./dist/service-content.d.ts",
        "import": "./dist/service-content.js",
        "default": "./dist/service-content.js"
      },
      "./service-content-synthesizer": {
        "types": "./dist/service-content-synthesizer.d.ts",
        "import": "./dist/service-content-synthesizer.js",
        "default": "./dist/service-content-synthesizer.js"
      },
      "./booking-overview-enricher": {
        "types": "./dist/booking-overview-enricher.d.ts",
        "import": "./dist/booking-overview-enricher.js",
        "default": "./dist/booking-overview-enricher.js"
      },
      "./service-owned-stays": {
        "types": "./dist/service-owned-stays.d.ts",
        "import": "./dist/service-owned-stays.js",
        "default": "./dist/service-owned-stays.js"
      },
      "./catalog-policy": {
        "types": "./dist/catalog-policy.d.ts",
        "import": "./dist/catalog-policy.js",
        "default": "./dist/catalog-policy.js"
      },
      "./service-catalog-plane": {
        "types": "./dist/service-catalog-plane.d.ts",
        "import": "./dist/service-catalog-plane.js",
        "default": "./dist/service-catalog-plane.js"
      },
      "./draft-shape": {
        "types": "./dist/draft-shape.d.ts",
        "import": "./dist/draft-shape.js",
        "default": "./dist/draft-shape.js"
      },
      "./booking-engine": {
        "types": "./dist/booking-engine/index.d.ts",
        "import": "./dist/booking-engine/index.js",
        "default": "./dist/booking-engine/index.js"
      },
      "./booking-engine/runtime": {
        "types": "./dist/booking-engine/runtime.d.ts",
        "import": "./dist/booking-engine/runtime.js",
        "default": "./dist/booking-engine/runtime.js"
      },
      "./routes-content": {
        "types": "./dist/routes-content.d.ts",
        "import": "./dist/routes-content.js",
        "default": "./dist/routes-content.js"
      },
      "./graph-runtime": {
        "types": "./dist/graph-runtime.d.ts",
        "import": "./dist/graph-runtime.js",
        "default": "./dist/graph-runtime.js"
      },
      "./runtime-contributor": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      },
      "./payment-policy-runtime": {
        "types": "./dist/payment-policy-runtime.d.ts",
        "import": "./dist/payment-policy-runtime.js",
        "default": "./dist/payment-policy-runtime.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      },
      "./openapi/admin": "./openapi/admin/accommodations.json",
      "./openapi/storefront": "./openapi/storefront/accommodations-content-public.json",
      "./catalog-runtime-extension": {
        "types": "./dist/catalog-runtime-extension.d.ts",
        "import": "./dist/catalog-runtime-extension.js",
        "default": "./dist/catalog-runtime-extension.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/accommodations"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "runtime": {
      "entry": "./runtime-contributor",
      "export": "createAccommodationsRuntimePortContribution"
    },
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    },
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/db",
      "@voyant-travel/operations",
      "@voyant-travel/bookings"
    ]
  }
}
