{
  "name": "@voyantjs/suppliers",
  "version": "0.59.0",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./validation": "./src/validation.ts",
    "./routes": "./src/routes.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@voyantjs/core": "workspace:*",
    "@voyantjs/db": "workspace:*",
    "@voyantjs/facilities": "workspace:*",
    "@voyantjs/hono": "workspace:*",
    "@voyantjs/identity": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@voyantjs/voyant-typescript-config": "workspace:*",
    "typescript": "^6.0.2"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./validation": {
        "types": "./dist/validation.d.ts",
        "import": "./dist/validation.js",
        "default": "./dist/validation.js"
      },
      "./routes": {
        "types": "./dist/routes.d.ts",
        "import": "./dist/routes.js",
        "default": "./dist/routes.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/suppliers"
  },
  "voyant": {
    "schema": "./schema",
    "requiresSchemas": [
      "@voyantjs/db",
      "@voyantjs/facilities"
    ]
  }
}
