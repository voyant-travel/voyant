{
  "name": "@voyant-travel/storage",
  "version": "0.109.4",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./conformance": "./src/conformance.ts",
    "./service": "./src/service.ts",
    "./routes": "./src/routes.ts",
    "./runtime-contributor": "./src/runtime-contributor.ts",
    "./runtime-port": "./src/runtime-port.ts",
    "./runtime": "./src/runtime.ts",
    "./voyant": "./src/voyant.ts",
    "./providers/local": "./src/providers/local.ts",
    "./providers/s3-compatible": "./src/providers/s3-compatible.ts",
    "./providers/graph": "./src/providers/graph.ts",
    "./openapi/admin/media": "./openapi/admin/storage-media.json",
    "./openapi/admin/uploads": "./openapi/admin/storage-uploads.json",
    "./openapi/admin/video-upload-ticket": "./openapi/admin/storage-video-upload-ticket.json"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig*.tsbuildinfo",
    "prepack": "pnpm run build"
  },
  "files": [
    "dist",
    "openapi"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./types": {
        "types": "./dist/types.d.ts",
        "import": "./dist/types.js",
        "default": "./dist/types.js"
      },
      "./conformance": {
        "types": "./dist/conformance.d.ts",
        "import": "./dist/conformance.js",
        "default": "./dist/conformance.js"
      },
      "./service": {
        "types": "./dist/service.d.ts",
        "import": "./dist/service.js",
        "default": "./dist/service.js"
      },
      "./routes": {
        "types": "./dist/routes.d.ts",
        "import": "./dist/routes.js",
        "default": "./dist/routes.js"
      },
      "./runtime-contributor": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      },
      "./runtime-port": {
        "types": "./dist/runtime-port.d.ts",
        "import": "./dist/runtime-port.js",
        "default": "./dist/runtime-port.js"
      },
      "./runtime": {
        "types": "./dist/runtime.d.ts",
        "import": "./dist/runtime.js",
        "default": "./dist/runtime.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      },
      "./providers/local": {
        "types": "./dist/providers/local.d.ts",
        "import": "./dist/providers/local.js",
        "default": "./dist/providers/local.js"
      },
      "./providers/s3-compatible": {
        "types": "./dist/providers/s3-compatible.d.ts",
        "import": "./dist/providers/s3-compatible.js",
        "default": "./dist/providers/s3-compatible.js"
      },
      "./providers/graph": {
        "types": "./dist/providers/graph.d.ts",
        "import": "./dist/providers/graph.js",
        "default": "./dist/providers/graph.js"
      },
      "./openapi/admin/media": "./openapi/admin/storage-media.json",
      "./openapi/admin/uploads": "./openapi/admin/storage-uploads.json",
      "./openapi/admin/video-upload-ticket": "./openapi/admin/storage-video-upload-ticket.json"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/cloud-sdk": "^0.11.0",
    "@voyant-travel/core": "workspace:^"
  },
  "peerDependencies": {
    "hono": "^4.12.25",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "hono": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/storage"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "runtime": {
      "entry": "./runtime-contributor",
      "export": "createStorageRuntimePortContribution"
    },
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    }
  }
}
