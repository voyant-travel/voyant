      },
      "./order-payment-sessions": {
        "types": "./dist/order-payment-sessions.d.ts",
        "import": "./dist/order-payment-sessions.js",
        "default": "./dist/order-payment-sessions.js"
      },
      "./payment-policy": {
        "types": "./dist/payment-policy.d.ts",
        "import": "./dist/payment-policy.js",
        "default": "./dist/payment-policy.js"
      },
      "./payment-policy-cascade": {
        "types": "./dist/payment-policy-cascade.d.ts",
        "import": "./dist/payment-policy-cascade.js",
        "default": "./dist/payment-policy-cascade.js"
      },
      "./payment-link": {
        "types": "./dist/payment-link.d.ts",
        "import": "./dist/payment-link.js",
        "default": "./dist/payment-link.js"
      },
      "./travel-credits": {
        "types": "./dist/service-travel-credits.d.ts",
        "import": "./dist/service-travel-credits.js",
        "default": "./dist/service-travel-credits.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./validation": {
        "types": "./dist/validation.d.ts",
        "import": "./dist/validation.js",
        "default": "./dist/validation.js"
      },
      "./booking-tax": {
        "types": "./dist/booking-tax.d.ts",
        "import": "./dist/booking-tax.js",
        "default": "./dist/booking-tax.js"
      },
      "./runtime-contributor": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      },
      "./runtime-port": {
        "types": "./dist/runtime-port.d.ts",
        "import": "./dist/runtime-port.js",
        "default": "./dist/runtime-port.js"
      },
      "./stale-booking-holds-runtime": {
        "types": "./dist/stale-booking-holds-runtime.d.ts",
        "import": "./dist/stale-booking-holds-runtime.js",
        "default": "./dist/stale-booking-holds-runtime.js"
      },
      "./booking-schedule-subscriber": {
        "types": "./dist/booking-schedule/subscriber-runtime.d.ts",
        "import": "./dist/booking-schedule/subscriber-runtime.js",
        "default": "./dist/booking-schedule/subscriber-runtime.js"
      },
      "./proforma-conversion-subscriber": {
        "types": "./dist/proforma-conversion-runtime.d.ts",
        "import": "./dist/proforma-conversion-runtime.js",
        "default": "./dist/proforma-conversion-runtime.js"
      },
      "./routes": {
        "types": "./dist/routes.d.ts",
        "import": "./dist/routes.js",
        "default": "./dist/routes.js"
      },
      "./public-routes": {
        "types": "./dist/routes-public.d.ts",
        "import": "./dist/routes-public.js",
        "default": "./dist/routes-public.js"
      },
      "./public-validation": {
