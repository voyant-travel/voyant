{
  "name": "@voyant-travel/finance",
  "version": "0.179.0",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./linkables": "./src/linkables.ts",
    "./action-ledger-drift": "./src/action-ledger-drift.ts",
    "./card-payment": "./src/card-payment.ts",
    "./checkout": "./src/checkout-service.ts",
    "./checkout-routes": "./src/checkout-routes.ts",
    "./checkout-validation": "./src/checkout-validation.ts",
    "./invoice-fx": "./src/invoice-fx.ts",
    "./reporting": "./src/reporting.ts",
    "./order-payment-sessions": "./src/order-payment-sessions.ts",
    "./payment-policy": "./src/payment-policy.ts",
    "./payment-policy-cascade": "./src/payment-policy-cascade.ts",
    "./payment-link": "./src/payment-link.ts",
    "./travel-credits": "./src/service-travel-credits.ts",
    "./schema": "./src/schema.ts",
    "./validation": "./src/validation.ts",
    "./booking-tax": "./src/booking-tax.ts",
    "./runtime-contributor": "./src/runtime-contributor.ts",
    "./runtime-port": "./src/runtime-port.ts",
    "./stale-booking-holds-runtime": "./src/stale-booking-holds-runtime.ts",
    "./booking-schedule-subscriber": "./src/booking-schedule/subscriber-runtime.ts",
    "./proforma-conversion-subscriber": "./src/proforma-conversion-runtime.ts",
    "./routes": "./src/routes.ts",
    "./public-routes": "./src/routes-public.ts",
    "./public-validation": "./src/validation-public.ts",
    "./tools": "./src/mcp-runtime.ts",
    "./setup/travel-credits": "./src/service-travel-credits-migration.ts",
    "./voyant": "./src/voyant.ts",
    "./openapi/admin": "./openapi/admin/finance.json",
    "./openapi/admin/booking-tax-settings": "./openapi/admin/booking-tax-settings.json",
    "./openapi/admin/booking-tax-preview": "./openapi/admin/booking-tax-preview.json",
    "./openapi/storefront": "./openapi/storefront/finance.json"
  },
  "scripts": {
    "typecheck": "NODE_OPTIONS=--max-old-space-size=8192 tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "generate:openapi": "node --import tsx scripts/generate-travel-credit-openapi.ts && biome format --write openapi/storefront/finance.json",
    "migrate:travel-credits": "node --experimental-strip-types --experimental-transform-types scripts/migrate-travel-credits.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=finance_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/action-ledger": "workspace:^",
    "@voyant-travel/bookings": "workspace:^",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/data-sdk": "^0.7.1",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "@voyant-travel/finance-contracts": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/payments": "workspace:^",
    "@voyant-travel/public-document-delivery": "workspace:^",
    "@voyant-travel/reporting-contracts": "workspace:^",
    "@voyant-travel/storage": "workspace:^",
    "@voyant-travel/utils": "workspace:^",
    "drizzle-orm": "catalog:",
    "fflate": "^0.8.2",
    "hono": "catalog:",
    "zod": "catalog:",
    "@voyant-travel/tools": "workspace:^"
  },
  "devDependencies": {
    "@voyant-travel/webhook-delivery": "workspace:^",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  },
  "files": [
    "dist",
    "openapi",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./linkables": {
