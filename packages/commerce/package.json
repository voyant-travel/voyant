{
  "name": "@voyant-travel/commerce",
  "version": "0.39.24",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./catalog-checkout-runner": "./src/checkout/runner-runtime.ts",
    "./catalog-checkout-subscribers": "./src/checkout/subscriber-runtime.ts",
    "./schema": "./src/schema.ts",
    "./checkout": "./src/checkout/index.ts",
    "./validation": "./src/validation.ts",
    "./tools": "./src/mcp-runtime.ts",
    "./promotion-redemption-subscriber": "./src/promotions/subscriber-runtime.ts",
    "./runtime-contributor": "./src/runtime-contributor.ts",
    "./runtime-port": "./src/runtime-port.ts",
    "./product-reindex-workflow-manifest": "./src/promotions/workflow-bulk-reindex-manifest.ts",
    "./product-reindex-workflow": "./src/promotions/workflow-bulk-reindex.ts",
    "./promotion-boundary-job": "./src/promotions/job-boundary-scheduler.ts",
    "./voyant": "./src/voyant.ts",
    "./openapi/admin/markets": "./openapi/admin/markets.json",
    "./openapi/admin/pricing": "./openapi/admin/pricing.json",
    "./openapi/admin/promotions": "./openapi/admin/promotions.json",
    "./openapi/admin/sellability": "./openapi/admin/sellability.json",
    "./openapi/storefront/markets": "./openapi/storefront/markets.json",
    "./openapi/storefront/pricing": "./openapi/storefront/pricing.json",
    "./catalog-runtime-extension": "./src/catalog-runtime-extension.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=commerce_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/bookings": "workspace:^",
    "@voyant-travel/catalog": "workspace:^",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "@voyant-travel/distribution": "workspace:^",
    "@voyant-travel/finance": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/tools": "workspace:^",
    "@voyant-travel/products-contracts": "workspace:^",
    "@voyant-travel/quotes-contracts": "workspace:^",
    "@voyant-travel/workflow-runs": "workspace:^",
    "@voyant-travel/workflows": "workspace:^",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "rrule": "^2.8.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "openapi",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./catalog-checkout-runner": {
        "types": "./dist/checkout/runner-runtime.d.ts",
        "import": "./dist/checkout/runner-runtime.js",
        "default": "./dist/checkout/runner-runtime.js"
      },
      "./catalog-checkout-subscribers": {
        "types": "./dist/checkout/subscriber-runtime.d.ts",
        "import": "./dist/checkout/subscriber-runtime.js",
        "default": "./dist/checkout/subscriber-runtime.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./checkout": {
        "types": "./dist/checkout/index.d.ts",
        "import": "./dist/checkout/index.js",
        "default": "./dist/checkout/index.js"
      },
      "./validation": {
        "types": "./dist/validation.d.ts",
        "import": "./dist/validation.js",
        "default": "./dist/validation.js"
      },
      "./tools": {
        "types": "./dist/mcp-runtime.d.ts",
        "import": "./dist/mcp-runtime.js",
        "default": "./dist/mcp-runtime.js"
      },
      "./promotion-redemption-subscriber": {
        "types": "./dist/promotions/subscriber-runtime.d.ts",
        "import": "./dist/promotions/subscriber-runtime.js",
        "default": "./dist/promotions/subscriber-runtime.js"
      },
      "./runtime-contributor": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      },
      "./runtime-port": {
        "types": "./dist/runtime-port.d.ts",
        "import": "./dist/runtime-port.js",
        "default": "./dist/runtime-port.js"
      },
      "./product-reindex-workflow-manifest": {
        "types": "./dist/promotions/workflow-bulk-reindex-manifest.d.ts",
        "import": "./dist/promotions/workflow-bulk-reindex-manifest.js",
        "default": "./dist/promotions/workflow-bulk-reindex-manifest.js"
      },
      "./product-reindex-workflow": {
        "types": "./dist/promotions/workflow-bulk-reindex.d.ts",
        "import": "./dist/promotions/workflow-bulk-reindex.js",
        "default": "./dist/promotions/workflow-bulk-reindex.js"
      },
      "./promotion-boundary-job": {
        "types": "./dist/promotions/job-boundary-scheduler.d.ts",
        "import": "./dist/promotions/job-boundary-scheduler.js",
        "default": "./dist/promotions/job-boundary-scheduler.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      },
      "./openapi/admin/markets": "./openapi/admin/markets.json",
      "./openapi/admin/pricing": "./openapi/admin/pricing.json",
      "./openapi/admin/promotions": "./openapi/admin/promotions.json",
      "./openapi/admin/sellability": "./openapi/admin/sellability.json",
      "./openapi/storefront/markets": "./openapi/storefront/markets.json",
      "./openapi/storefront/pricing": "./openapi/storefront/pricing.json",
      "./catalog-runtime-extension": {
        "types": "./dist/catalog-runtime-extension.d.ts",
        "import": "./dist/catalog-runtime-extension.js",
        "default": "./dist/catalog-runtime-extension.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/commerce"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "runtime": {
      "entry": "./runtime-contributor",
      "export": "createCommerceRuntimePortContribution"
    },
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    },
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/db"
    ]
  }
}
