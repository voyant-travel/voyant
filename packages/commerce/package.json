{
  "name": "@voyantjs/commerce",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@voyantjs/core": "workspace:^",
    "@voyantjs/hono": "workspace:^",
    "@voyantjs/markets": "workspace:^",
    "@voyantjs/pricing": "workspace:^",
    "@voyantjs/promotions": "workspace:^",
    "@voyantjs/sellability": "workspace:^"
  },
  "devDependencies": {
    "@voyantjs/voyant-typescript-config": "workspace:^",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/commerce"
  }
}
