{
  "openapi": "3.1.0",
  "info": {
    "title": "Booking Product Details API",
    "version": "1.0.0"
  },
  "paths": {
    "/v1/admin/bookings/{bookingId}/product-details": {
      "parameters": [
        { "name": "bookingId", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "summary": "Get product details attached to a booking",
        "x-voyant-api-id": "@voyant-travel/inventory#booking-extension.api",
        "responses": { "200": { "description": "Booking product details, or null when absent" } }
      },
      "put": {
        "summary": "Create or replace product details on a booking",
        "x-voyant-api-id": "@voyant-travel/inventory#booking-extension.api",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BookingProductDetailsInput" }
            }
          }
        },
        "responses": { "200": { "description": "Booking product details were stored" } }
      },
      "delete": {
        "summary": "Remove product details from a booking",
        "x-voyant-api-id": "@voyant-travel/inventory#booking-extension.api",
        "responses": {
          "200": { "description": "Booking product details were removed" },
          "404": { "description": "No product details exist for the booking" }
        }
      }
    },
    "/v1/admin/bookings/{bookingId}/items/{itemId}/product-details": {
      "parameters": [
        { "name": "bookingId", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "summary": "Get product details attached to a booking item",
        "x-voyant-api-id": "@voyant-travel/inventory#booking-extension.api",
        "responses": {
          "200": { "description": "Booking item product details, or null when absent" }
        }
      },
      "put": {
        "summary": "Create or replace product details on a booking item",
        "x-voyant-api-id": "@voyant-travel/inventory#booking-extension.api",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BookingItemProductDetailsInput" }
            }
          }
        },
        "responses": { "200": { "description": "Booking item product details were stored" } }
      },
      "delete": {
        "summary": "Remove product details from a booking item",
        "x-voyant-api-id": "@voyant-travel/inventory#booking-extension.api",
        "responses": {
          "200": { "description": "Booking item product details were removed" },
          "404": { "description": "No product details exist for the booking item" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BookingProductDetailsInput": {
        "type": "object",
        "properties": {
          "productId": { "type": ["string", "null"] },
          "optionId": { "type": ["string", "null"] }
        }
      },
      "BookingItemProductDetailsInput": {
        "type": "object",
        "properties": {
          "productId": { "type": ["string", "null"] },
          "optionId": { "type": ["string", "null"] },
          "unitId": { "type": ["string", "null"] },
          "supplierServiceId": { "type": ["string", "null"] }
        }
      }
    }
  }
}
