{
  "name": "@voyant-travel/operations",
  "version": "0.2.8",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./availability": "./src/availability/index.ts",
    "./resources": "./src/resources/index.ts",
    "./ground": "./src/ground/index.ts",
    "./places": "./src/places/index.ts",
    "./schema": "./src/schema.ts",
    "./validation": "./src/validation.ts",
    "./routes": "./src/routes.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=operations_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@voyant-travel/availability": "workspace:^",
    "@voyant-travel/catalog": "workspace:^",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/identity": "workspace:^",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "files": [
    "dist",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./availability": {
        "types": "./dist/availability/index.d.ts",
        "import": "./dist/availability/index.js",
        "default": "./dist/availability/index.js"
      },
      "./resources": {
        "types": "./dist/resources/index.d.ts",
        "import": "./dist/resources/index.js",
        "default": "./dist/resources/index.js"
      },
      "./ground": {
        "types": "./dist/ground/index.d.ts",
        "import": "./dist/ground/index.js",
        "default": "./dist/ground/index.js"
      },
      "./places": {
        "types": "./dist/places/index.d.ts",
        "import": "./dist/places/index.js",
        "default": "./dist/places/index.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./validation": {
        "types": "./dist/validation.d.ts",
        "import": "./dist/validation.js",
        "default": "./dist/validation.js"
      },
      "./routes": {
        "types": "./dist/routes.d.ts",
        "import": "./dist/routes.js",
        "default": "./dist/routes.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/operations"
  },
  "voyant": {
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/availability",
      "@voyant-travel/db",
      "@voyant-travel/identity"
    ]
  }
}
