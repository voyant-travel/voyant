{
  "name": "@voyant-travel/operations",
  "version": "0.8.31",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./dashboard": "./src/dashboard.ts",
    "./linkables": "./src/linkables.ts",
    "./scheduling": "./src/availability/slot-timezone.ts",
    "./schema": "./src/schema.ts",
    "./validation": "./src/validation.ts",
    "./tools": "./src/mcp-runtime.ts",
    "./routes": "./src/routes.ts",
    "./voyant": "./src/voyant.ts",
    "./openapi/admin": "./openapi/admin/operations.json",
    "./catalog-runtime-extension": "./src/catalog-runtime-extension.ts",
    "./runtime-contributor": "./src/runtime-contributor.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=operations_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/allotments": "workspace:^",
    "@voyant-travel/availability": "workspace:^",
    "@voyant-travel/catalog": "workspace:^",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/identity": "workspace:^",
    "@voyant-travel/tools": "workspace:^",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "openapi",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./dashboard": {
        "types": "./dist/dashboard.d.ts",
        "import": "./dist/dashboard.js",
        "default": "./dist/dashboard.js"
      },
      "./scheduling": {
        "types": "./dist/availability/slot-timezone.d.ts",
        "import": "./dist/availability/slot-timezone.js",
        "default": "./dist/availability/slot-timezone.js"
      },
      "./linkables": {
        "types": "./dist/linkables.d.ts",
        "import": "./dist/linkables.js",
        "default": "./dist/linkables.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./validation": {
        "types": "./dist/validation.d.ts",
        "import": "./dist/validation.js",
        "default": "./dist/validation.js"
      },
      "./tools": {
        "types": "./dist/mcp-runtime.d.ts",
        "import": "./dist/mcp-runtime.js",
        "default": "./dist/mcp-runtime.js"
      },
      "./routes": {
        "types": "./dist/routes.d.ts",
        "import": "./dist/routes.js",
        "default": "./dist/routes.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      },
      "./openapi/admin": "./openapi/admin/operations.json",
      "./catalog-runtime-extension": {
        "types": "./dist/catalog-runtime-extension.d.ts",
        "import": "./dist/catalog-runtime-extension.js",
        "default": "./dist/catalog-runtime-extension.js"
      },
      "./runtime-contributor": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/operations"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    },
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/availability",
      "@voyant-travel/db",
      "@voyant-travel/identity"
    ],
    "runtime": {
      "entry": "./runtime-contributor",
      "export": "createOperationsRuntimePortContribution"
    }
  }
}
