{
  "name": "@voyantjs/action-ledger-react",
  "version": "0.5.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/action-ledger-react"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./provider": "./src/provider.tsx",
    "./admin": "./src/admin/index.tsx"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ tests/",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@voyantjs/action-ledger": "workspace:^",
    "@voyantjs/admin": "workspace:^",
    "@voyantjs/bookings-react": "workspace:^",
    "@voyantjs/crm-react": "workspace:^",
    "@voyantjs/products-react": "workspace:^",
    "@voyantjs/ui": "workspace:^",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@voyantjs/admin": {
      "optional": true
    },
    "@voyantjs/bookings-react": {
      "optional": true
    },
    "@voyantjs/crm-react": {
      "optional": true
    },
    "@voyantjs/products-react": {
      "optional": true
    },
    "@voyantjs/ui": {
      "optional": true
    }
  },
  "dependencies": {
    "@voyantjs/i18n": "workspace:^",
    "@voyantjs/react": "workspace:^"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.100.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@voyantjs/action-ledger": "workspace:^",
    "@voyantjs/admin": "workspace:^",
    "@voyantjs/bookings-react": "workspace:^",
    "@voyantjs/crm-react": "workspace:^",
    "@voyantjs/i18n": "workspace:^",
    "@voyantjs/products-react": "workspace:^",
    "@voyantjs/react": "workspace:^",
    "@voyantjs/ui": "workspace:^",
    "@voyantjs/voyant-typescript-config": "workspace:^",
    "lucide-react": "^0.475.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./provider": {
        "types": "./dist/provider.d.ts",
        "import": "./dist/provider.js",
        "default": "./dist/provider.js"
      },
      "./admin": {
        "types": "./dist/admin/index.d.ts",
        "import": "./dist/admin/index.js",
        "default": "./dist/admin/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  }
}
