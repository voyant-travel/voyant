{
  "name": "@voyant-travel/admin-host",
  "version": "0.2.1",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./destinations": "./src/admin-destinations.ts",
    "./presentation": "./src/admin-presentation.ts",
    "./workspace": "./src/workspace.tsx",
    "./standard-route-files": "./src/standard-route-files.ts",
    "./serve": "./src/serve.ts",
    "./ssr": "./src/ssr.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-router": "^1.0.0",
    "@tanstack/react-start": "^1.168.27",
    "@voyant-travel/admin": "workspace:^",
    "@voyant-travel/admin-app": "workspace:^",
    "@voyant-travel/admin-react": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "@voyant-travel/vite-config": "workspace:^",
    "hono": "^4.12.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@voyant-travel/runtime": "workspace:^"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "@types/node": "catalog:",
    "@voyant-travel/admin": "workspace:^",
    "@voyant-travel/admin-app": "workspace:^",
    "@voyant-travel/admin-react": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "@voyant-travel/vite-config": "workspace:^",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "hono": "catalog:",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./destinations": {
        "types": "./dist/admin-destinations.d.ts",
        "import": "./dist/admin-destinations.js",
        "default": "./dist/admin-destinations.js"
      },
      "./presentation": {
        "types": "./dist/admin-presentation.d.ts",
        "import": "./dist/admin-presentation.js",
        "default": "./dist/admin-presentation.js"
      },
      "./workspace": {
        "types": "./dist/workspace.d.ts",
        "import": "./dist/workspace.js",
        "default": "./dist/workspace.js"
      },
      "./standard-route-files": {
        "types": "./dist/standard-route-files.d.ts",
        "import": "./dist/standard-route-files.js",
        "default": "./dist/standard-route-files.js"
      },
      "./serve": {
        "types": "./dist/serve.d.ts",
        "import": "./dist/serve.js",
        "default": "./dist/serve.js"
      },
      "./ssr": {
        "types": "./dist/ssr.d.ts",
        "import": "./dist/ssr.js",
        "default": "./dist/ssr.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/admin-host"
  }
}
