{
  "name": "@voyant-travel/operator-settings",
  "version": "0.2.23",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./service": "./src/service.ts",
    "./hono-module": "./src/hono-module.ts",
    "./routes": "./src/routes.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=operator_settings_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/finance": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./service": {
        "types": "./dist/service.d.ts",
        "import": "./dist/service.js",
        "default": "./dist/service.js"
      },
      "./hono-module": {
        "types": "./dist/hono-module.d.ts",
        "import": "./dist/hono-module.js",
        "default": "./dist/hono-module.js"
      },
      "./routes": {
        "types": "./dist/routes.d.ts",
        "import": "./dist/routes.js",
        "default": "./dist/routes.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/operator-settings"
  },
  "voyant": {
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/db"
    ]
  }
}
