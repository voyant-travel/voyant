{
  "name": "@voyant-travel/runtime",
  "version": "0.11.9",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./deployment-resources": "./src/deployment-resources.ts",
    "./workflow-entry": "./src/workflow-entry.ts",
    "./openapi": "./src/openapi.ts",
    "./tooling": "./src/tooling.ts"
  },
  "scripts": {
    "build": "pnpm run clean && NODE_OPTIONS=--max-old-space-size=14336 tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig*.tsbuildinfo",
    "prepack": "pnpm --workspace-concurrency=1 --filter @voyant-travel/runtime... run build",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=14336 tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/devtools-vite": "^0.8.1",
    "@tanstack/react-start": "^1.168.27",
    "@tanstack/router-generator": "1.167.18",
    "@vitejs/plugin-react": "^6.0.3",
    "@voyant-travel/admin-host": "workspace:^",
    "@voyant-travel/auth": "workspace:^",
    "@voyant-travel/cloud-sdk": "^0.11.0",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/framework": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/runtime-core": "workspace:^",
    "@voyant-travel/storage": "workspace:^",
    "@voyant-travel/vite-config": "workspace:^",
    "@voyant-travel/webhook-delivery": "workspace:^",
    "@voyant-travel/workflow-runs": "workspace:^",
    "hono": "catalog:",
    "srvx": "^0.11.22",
    "tsx": "catalog:",
    "vite": "catalog:"
  },
  "devDependencies": {
    "@hono/zod-openapi": "catalog:",
    "@types/node": "catalog:",
    "@voyant-travel/accommodations": "workspace:^",
    "@voyant-travel/bookings": "workspace:^",
    "@voyant-travel/cruises": "workspace:^",
    "@voyant-travel/finance": "workspace:^",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-orm": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./deployment-resources": {
        "types": "./dist/deployment-resources.d.ts",
        "import": "./dist/deployment-resources.js",
        "default": "./dist/deployment-resources.js"
      },
      "./workflow-entry": {
        "types": "./dist/workflow-entry.d.ts",
        "import": "./dist/workflow-entry.js",
        "default": "./dist/workflow-entry.js"
      },
      "./openapi": {
        "types": "./dist/openapi.d.ts",
        "import": "./dist/openapi.js",
        "default": "./dist/openapi.js"
      },
      "./tooling": {
        "types": "./dist/tooling.d.ts",
        "import": "./dist/tooling.js",
        "default": "./dist/tooling.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/runtime"
  }
}
