  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/fix-esm-imports.mjs",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=db_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations pg_trgm unaccent"
