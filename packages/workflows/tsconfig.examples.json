{
  "extends": "@voyant-travel/voyant-typescript-config/library.json",
  "compilerOptions": {
    "outDir": "examples-dist",
    "rootDir": "examples",
    "baseUrl": ".",
    "paths": {
      "@voyant-travel/workflows": ["./dist/index.d.ts"],
      "@voyant-travel/workflows/testing": ["./dist/testing/index.d.ts"],
      "@voyant-travel/workflows/protocol": ["./dist/protocol/index.d.ts"]
    },
    "types": ["node"],
    "declaration": false,
    "declarationMap": false
  },
  "include": ["examples/**/*"],
  "exclude": ["dist", "examples-dist", "node_modules", "src"]
}
