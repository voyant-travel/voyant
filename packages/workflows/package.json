{
  "name": "@voyantjs/workflows",
  "version": "0.37.1",
  "description": "Authoring SDK for Voyant Workflows — durable, step-based orchestrations for Voyant Cloud.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/workflows"
  },
  "homepage": "https://voyant.cloud/workflows",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "import": "./src/testing/index.ts"
    },
    "./protocol": {
      "types": "./src/protocol/index.ts",
      "import": "./src/protocol/index.ts"
    },
    "./handler": {
      "types": "./src/handler/index.ts",
      "import": "./src/handler/index.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "import": "./src/auth/index.ts"
    },
    "./bindings": {
      "types": "./src/bindings.ts",
      "import": "./src/bindings.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./src/config.ts"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "import": "./src/errors.ts"
    },
    "./rate-limit": {
      "types": "./src/rate-limit/index.ts",
      "import": "./src/rate-limit/index.ts"
    },
    "./driver": {
      "types": "./src/driver.ts",
      "import": "./src/driver.ts"
    },
    "./events": {
      "types": "./src/events/index.ts",
      "import": "./src/events/index.ts"
    },
    "./http-ingest": {
      "types": "./src/http-ingest.ts",
      "import": "./src/http-ingest.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!**/*.test.*",
    "!**/*.spec.*",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:examples": "tsc -p tsconfig.examples.json",
    "spike": "pnpm build && pnpm build:examples && node examples-dist/drive.js",
    "check-types": "tsc --noEmit",
    "dev": "tsc -w -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@voyantjs/voyant-typescript-config": "workspace:*",
    "typescript": "^5.9.2",
    "vitest": "^3.2.0"
  },
  "peerDependencies": {
    "zod": "^3.23.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./testing": {
        "types": "./dist/testing/index.d.ts",
        "import": "./dist/testing/index.js"
      },
      "./protocol": {
        "types": "./dist/protocol/index.d.ts",
        "import": "./dist/protocol/index.js"
      },
      "./handler": {
        "types": "./dist/handler/index.d.ts",
        "import": "./dist/handler/index.js"
      },
      "./auth": {
        "types": "./dist/auth/index.d.ts",
        "import": "./dist/auth/index.js"
      },
      "./bindings": {
        "types": "./dist/bindings.d.ts",
        "import": "./dist/bindings.js"
      },
      "./config": {
        "types": "./dist/config.d.ts",
        "import": "./dist/config.js"
      },
      "./errors": {
        "types": "./dist/errors.d.ts",
        "import": "./dist/errors.js"
      },
      "./rate-limit": {
        "types": "./dist/rate-limit/index.d.ts",
        "import": "./dist/rate-limit/index.js"
      },
      "./driver": {
        "types": "./dist/driver.d.ts",
        "import": "./dist/driver.js"
      },
      "./events": {
        "types": "./dist/events/index.d.ts",
        "import": "./dist/events/index.js"
      },
      "./http-ingest": {
        "types": "./dist/http-ingest.d.ts",
        "import": "./dist/http-ingest.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  }
