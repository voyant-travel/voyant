{
  "name": "@voyantjs/admin",
  "version": "0.19.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./extensions": "./src/extensions.ts",
    "./providers/theme": "./src/providers/theme.tsx",
    "./providers/locale": "./src/providers/locale.tsx",
    "./providers/query-client": "./src/providers/query-client.ts",
    "./providers/admin-provider": "./src/providers/admin-provider.tsx",
    "./lib/i18n": "./src/lib/i18n.tsx",
    "./lib/initials": "./src/lib/initials.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@voyantjs/i18n": "workspace:*"
  },
  "devDependencies": {
    "@voyantjs/voyant-typescript-config": "workspace:*",
    "@tanstack/react-query": "^5.96.2",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^25.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./extensions": {
        "types": "./dist/extensions.d.ts",
        "import": "./dist/extensions.js",
        "default": "./dist/extensions.js"
      },
      "./providers/theme": {
        "types": "./dist/providers/theme.d.ts",
        "import": "./dist/providers/theme.js",
        "default": "./dist/providers/theme.js"
      },
      "./providers/locale": {
        "types": "./dist/providers/locale.d.ts",
        "import": "./dist/providers/locale.js",
        "default": "./dist/providers/locale.js"
      },
      "./providers/query-client": {
        "types": "./dist/providers/query-client.d.ts",
        "import": "./dist/providers/query-client.js",
        "default": "./dist/providers/query-client.js"
      },
      "./providers/admin-provider": {
        "types": "./dist/providers/admin-provider.d.ts",
        "import": "./dist/providers/admin-provider.js",
        "default": "./dist/providers/admin-provider.js"
      },
      "./lib/i18n": {
        "types": "./dist/lib/i18n.d.ts",
        "import": "./dist/lib/i18n.js",
        "default": "./dist/lib/i18n.js"
      },
      "./lib/initials": {
        "types": "./dist/lib/initials.d.ts",
        "import": "./dist/lib/initials.js",
        "default": "./dist/lib/initials.js"
      },
      "./types": {
        "types": "./dist/types.d.ts",
        "import": "./dist/types.js",
        "default": "./dist/types.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/admin"
  }
}
