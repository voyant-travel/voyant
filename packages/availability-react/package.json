{
  "name": "@voyantjs/availability-react",
  "version": "0.111.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/availability-react"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./provider": "./src/provider.tsx",
    "./hooks": "./src/hooks/index.ts",
    "./client": "./src/client.ts",
    "./query-keys": "./src/query-keys.ts",
    "./ui": "./src/ui.ts",
    "./styles.css": "./src/styles.css",
    "./i18n": "./src/i18n/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./admin": "./src/admin/index.tsx",
    "./admin/*": "./src/admin/*.tsx",
    "./utils": "./src/utils.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-table": "^8.21.3",
    "@voyantjs/admin": "workspace:^",
    "@voyantjs/allocation-ui": "workspace:^",
    "@voyantjs/availability": "workspace:^",
    "@voyantjs/bookings-react": "workspace:^",
    "@voyantjs/extras-react": "workspace:^",
    "@voyantjs/products-react": "workspace:^",
    "@voyantjs/ui": "workspace:^",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "sonner": "^2.0.7",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-table": {
      "optional": true
    },
    "@voyantjs/admin": {
      "optional": true
    },
    "@voyantjs/allocation-ui": {
      "optional": true
    },
    "@voyantjs/bookings-react": {
      "optional": true
    },
    "@voyantjs/extras-react": {
      "optional": true
    },
    "@voyantjs/products-react": {
      "optional": true
    },
    "@voyantjs/ui": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    },
    "sonner": {
      "optional": true
    }
  },
  "dependencies": {
    "@voyantjs/i18n": "workspace:^",
    "@voyantjs/react": "workspace:^"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-table": "^8.21.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@voyantjs/admin": "workspace:^",
    "@voyantjs/allocation-ui": "workspace:^",
    "@voyantjs/availability": "workspace:^",
    "@voyantjs/bookings-react": "workspace:^",
    "@voyantjs/extras-react": "workspace:^",
    "@voyantjs/i18n": "workspace:^",
    "@voyantjs/products-react": "workspace:^",
    "@voyantjs/react": "workspace:^",
    "@voyantjs/ui": "workspace:^",
    "@voyantjs/voyant-typescript-config": "workspace:^",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "sonner": "^2.0.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "src/styles.css"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./provider": {
        "types": "./dist/provider.d.ts",
        "import": "./dist/provider.js",
        "default": "./dist/provider.js"
      },
      "./hooks": {
        "types": "./dist/hooks/index.d.ts",
        "import": "./dist/hooks/index.js",
        "default": "./dist/hooks/index.js"
      },
      "./client": {
        "types": "./dist/client.d.ts",
        "import": "./dist/client.js",
        "default": "./dist/client.js"
      },
      "./query-keys": {
        "types": "./dist/query-keys.d.ts",
        "import": "./dist/query-keys.js",
        "default": "./dist/query-keys.js"
      },
      "./ui": {
        "types": "./dist/ui.d.ts",
        "import": "./dist/ui.js",
        "default": "./dist/ui.js"
      },
      "./styles.css": {
        "default": "./src/styles.css"
      },
      "./i18n": {
        "types": "./dist/i18n/index.d.ts",
        "import": "./dist/i18n/index.js",
        "default": "./dist/i18n/index.js"
      },
      "./components/*": {
        "types": "./dist/components/*.d.ts",
        "import": "./dist/components/*.js",
        "default": "./dist/components/*.js"
      },
      "./admin": {
        "types": "./dist/admin/index.d.ts",
        "import": "./dist/admin/index.js",
        "default": "./dist/admin/index.js"
      },
      "./utils": {
        "types": "./dist/utils.d.ts",
        "import": "./dist/utils.js",
        "default": "./dist/utils.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  }
}
