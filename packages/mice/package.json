{
  "name": "@voyant-travel/mice",
  "version": "0.21.0",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./linkables": "./src/linkables.ts",
    "./standard-links": "./src/standard-links.ts",
    "./schema": "./src/schema.ts",
    "./validation": "./src/validation.ts",
    "./routes": "./src/routes.ts",
    "./booking-extension": "./src/booking-extension.ts",
    "./runtime-contributor": "./src/runtime-contributor.ts",
    "./tools": "./src/tools.ts",
    "./mcp-runtime": "./src/mcp-runtime.ts",
    "./voyant": "./src/voyant.ts",
    "./openapi/admin": "./openapi/admin/mice.json",
    "./openapi/admin/mice-booking": "./openapi/admin/mice-booking.json"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=mice_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/accommodations": "workspace:^",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/operations": "workspace:^",
    "@voyant-travel/tools": "workspace:^",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@voyant-travel/bookings": "workspace:^",
    "@voyant-travel/distribution": "workspace:^",
    "@voyant-travel/quotes": "workspace:^",
    "@voyant-travel/relationships": "workspace:^"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "openapi",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./linkables": {
        "types": "./dist/linkables.d.ts",
        "import": "./dist/linkables.js",
        "default": "./dist/linkables.js"
      },
      "./standard-links": {
        "types": "./dist/standard-links.d.ts",
        "import": "./dist/standard-links.js",
        "default": "./dist/standard-links.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./validation": {
        "types": "./dist/validation.d.ts",
        "import": "./dist/validation.js",
        "default": "./dist/validation.js"
      },
      "./routes": {
        "types": "./dist/routes.d.ts",
        "import": "./dist/routes.js",
        "default": "./dist/routes.js"
      },
      "./booking-extension": {
        "types": "./dist/booking-extension.d.ts",
        "import": "./dist/booking-extension.js",
        "default": "./dist/booking-extension.js"
      },
      "./runtime-contributor": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      },
      "./tools": {
        "types": "./dist/tools.d.ts",
        "import": "./dist/tools.js",
        "default": "./dist/tools.js"
      },
      "./mcp-runtime": {
        "types": "./dist/mcp-runtime.d.ts",
        "import": "./dist/mcp-runtime.js",
        "default": "./dist/mcp-runtime.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      },
      "./openapi/admin": "./openapi/admin/mice.json",
      "./openapi/admin/mice-booking": "./openapi/admin/mice-booking.json"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/mice"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "runtime": {
      "entry": "./runtime-contributor",
      "export": "createMiceRuntimePortContribution"
    },
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    },
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/db",
      "@voyant-travel/accommodations",
      "@voyant-travel/operations"
    ]
  }
}
