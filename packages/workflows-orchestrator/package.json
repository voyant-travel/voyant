{
  "name": "@voyant-travel/workflows-orchestrator",
  "version": "0.111.14",
  "description": "Postgres self-host orchestrator runtime for Voyant Workflows — drives runs through the tenant step handler over the v1 wire protocol.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/workflows-orchestrator"
  },
  "homepage": "https://voyant.cloud/workflows",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./in-memory": {
      "types": "./src/driver-inmemory.ts",
      "development": "./src/driver-inmemory.ts",
      "node": "./dist/driver-inmemory.js",
      "import": "./src/driver-inmemory.ts",
      "default": "./src/driver-inmemory.ts"
    },
    "./selfhost": {
      "types": "./src/node/index.ts",
      "development": "./src/node/index.ts",
      "node": "./dist/node/index.js",
      "import": "./src/node/index.ts",
      "default": "./dist/node/index.js"
    },
    "./testing": {
      "types": "./src/testing/driver-compliance.ts",
      "development": "./src/testing/driver-compliance.ts",
      "node": "./dist/testing/driver-compliance.js",
      "import": "./src/testing/driver-compliance.ts",
      "default": "./src/testing/driver-compliance.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "drizzle",
    "src",
    "!**/*.test.*",
    "!**/*.spec.*",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "dev": "tsc -w -p tsconfig.json",
    "test:integration": "vitest run --maxWorkers=1 --testTimeout=30000 --hookTimeout=30000 src/node/__tests__/migrate.integration.test.ts src/node/__tests__/postgres-integration.test.ts src/node/__tests__/selfhost-server-postgres.integration.test.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@voyant-travel/workflows": "workspace:^",
    "drizzle-orm": "catalog:",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "node": "./dist/index.js",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./in-memory": {
        "types": "./dist/driver-inmemory.d.ts",
        "node": "./dist/driver-inmemory.js",
        "import": "./dist/driver-inmemory.js",
        "default": "./dist/driver-inmemory.js"
      },
      "./selfhost": {
        "types": "./dist/node/index.d.ts",
        "node": "./dist/node/index.js",
        "import": "./dist/node/index.js",
        "default": "./dist/node/index.js"
      },
      "./testing": {
        "types": "./dist/testing/driver-compliance.d.ts",
        "node": "./dist/testing/driver-compliance.js",
        "import": "./dist/testing/driver-compliance.js",
        "default": "./dist/testing/driver-compliance.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  }
}
