{
  "name": "@voyantjs/workflows-react",
  "version": "0.77.10",
  "description": "React hooks for Voyant Workflows — trigger, subscribe, and stream runs.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/workflows-react"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./workflow-runs": "./src/workflow-runs.ts",
    "./workflow-runs-client": "./src/workflow-runs-client.ts",
    "./workflow-schedules-client": "./src/workflow-schedules-client.ts"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!**/*.test.*",
    "!**/*.spec.*",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests",
    "dev": "tsc -w -p tsconfig.json"
  },
  "dependencies": {
    "@voyantjs/react": "workspace:*",
    "@voyantjs/workflows": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.100.11",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.2.3",
    "@voyantjs/react": "workspace:*",
    "@voyantjs/voyant-typescript-config": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.2",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./workflow-runs": {
        "types": "./dist/workflow-runs.d.ts",
        "import": "./dist/workflow-runs.js",
        "default": "./dist/workflow-runs.js"
      },
      "./workflow-runs-client": {
        "types": "./dist/workflow-runs-client.d.ts",
        "import": "./dist/workflow-runs-client.js",
        "default": "./dist/workflow-runs-client.js"
      },
      "./workflow-schedules-client": {
        "types": "./dist/workflow-schedules-client.d.ts",
        "import": "./dist/workflow-schedules-client.js",
        "default": "./dist/workflow-schedules-client.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  }
}
