{
  "name": "@voyant-travel/catalog-authoring",
  "version": "0.107.6",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./spec": "./src/spec.ts",
    "./extension": "./src/extension.ts",
    "./voyant": "./src/voyant.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=catalog_authoring_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/inventory": "workspace:^"
  },
  "devDependencies": {
    "@voyant-travel/commerce": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/inventory": "workspace:^",
    "@voyant-travel/operations": "workspace:^",
    "@voyant-travel/voyant-test-utils": "workspace:^",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "files": [
    "dist",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./spec": {
        "types": "./dist/spec.d.ts",
        "import": "./dist/spec.js",
        "default": "./dist/spec.js"
      },
      "./extension": {
        "types": "./dist/extension.d.ts",
        "import": "./dist/extension.js",
        "default": "./dist/extension.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/catalog-authoring"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    },
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/db",
      "@voyant-travel/inventory",
      "@voyant-travel/commerce",
      "@voyant-travel/operations"
    ]
  }
}
