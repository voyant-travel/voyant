{
  "name": "@voyantjs/catalog-authoring",
  "version": "0.106.14",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./spec": "./src/spec.ts",
    "./extension": "./src/extension.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@voyantjs/availability": "workspace:^",
    "@voyantjs/core": "workspace:^",
    "@voyantjs/db": "workspace:^",
    "@voyantjs/extras": "workspace:^",
    "@voyantjs/hono": "workspace:^",
    "@voyantjs/pricing": "workspace:^",
    "@voyantjs/products": "workspace:^",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@voyantjs/voyant-test-utils": "workspace:^",
    "@voyantjs/voyant-typescript-config": "workspace:^",
    "typescript": "^6.0.2"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./spec": {
        "types": "./dist/spec.d.ts",
        "import": "./dist/spec.js",
        "default": "./dist/spec.js"
      },
      "./extension": {
        "types": "./dist/extension.d.ts",
        "import": "./dist/extension.js",
        "default": "./dist/extension.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/catalog-authoring"
  },
  "voyant": {
    "schema": "./schema",
    "requiresSchemas": [
      "@voyantjs/db",
      "@voyantjs/products",
      "@voyantjs/pricing",
      "@voyantjs/availability",
      "@voyantjs/extras"
    ]
  }
}
