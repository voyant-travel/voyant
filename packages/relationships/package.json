{
  "name": "@voyant-travel/relationships",
  "version": "0.120.11",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./events": "./src/events.ts",
    "./schema": "./src/schema.ts",
    "./validation": "./src/validation.ts",
    "./routes": "./src/routes/index.ts",
    "./action-ledger-capabilities": "./src/action-ledger-capabilities.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=relationships_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@voyant-travel/action-ledger": "workspace:^",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/relationships-contracts": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/identity": "workspace:^",
    "@voyant-travel/utils": "workspace:^",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  },
  "files": [
    "dist",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./events": {
        "types": "./dist/events.d.ts",
        "import": "./dist/events.js",
        "default": "./dist/events.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./validation": {
        "types": "./dist/validation.d.ts",
        "import": "./dist/validation.js",
        "default": "./dist/validation.js"
      },
      "./routes": {
        "types": "./dist/routes/index.d.ts",
        "import": "./dist/routes/index.js",
        "default": "./dist/routes/index.js"
      },
      "./action-ledger-capabilities": {
        "types": "./dist/action-ledger-capabilities.d.ts",
        "import": "./dist/action-ledger-capabilities.js",
        "default": "./dist/action-ledger-capabilities.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/relationships"
  },
  "voyant": {
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/db"
    ]
  }
}
