{
  "name": "@voyant-travel/operator-standard",
  "version": "0.1.0",
  "description": "Versioned standard Voyant Operator product distribution and dependency BOM.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./standard-frontend": "./src/standard-frontend.tsx",
    "./standard-route-files": "./src/standard-route-files.ts",
    "./standard-styles.css": "./src/standard-styles.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noCheck",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run typecheck && pnpm run build",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests"
  },
