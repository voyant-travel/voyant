  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src/standard-styles.css"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./standard-frontend": {
        "types": "./dist/standard-frontend.d.ts",
        "import": "./dist/standard-frontend.js",
        "default": "./dist/standard-frontend.js"
      },
      "./standard-route-files": {
        "types": "./dist/standard-route-files.d.ts",
        "import": "./dist/standard-route-files.js",
        "default": "./dist/standard-route-files.js"
      },
      "./standard-styles.css": {
        "default": "./src/standard-styles.css"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/operator-standard"
