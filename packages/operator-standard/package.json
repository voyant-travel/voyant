  "version": "0.1.0",
  "description": "Versioned standard Voyant Operator product distribution and dependency BOM.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
