{
  "name": "@voyant-travel/storefront",
  "version": "0.150.0",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./admin-routes": "./src/routes-admin.ts",
    "./customer-portal": "./src/customer-portal/index.ts",
    "./customer-portal/public-routes": "./src/customer-portal/routes-public.ts",
    "./customer-portal/public-validation": "./src/customer-portal/validation-public.ts",
    "./customer-portal/routes": "./src/customer-portal/routes.ts",
    "./payment-link": "./src/payment-link/routes.ts",
    "./public-routes": "./src/routes-public.ts",
    "./service": "./src/service.ts",
    "./transport-eligibility": "./src/transport-eligibility.ts",
    "./validation": "./src/validation.ts",
    "./verification": "./src/verification/index.ts",
    "./verification/schema": "./src/verification/schema.ts",
    "./verification/public-routes": "./src/verification/routes-public.ts",
    "./verification/service": "./src/verification/service.ts",
    "./verification/validation": "./src/verification/validation.ts"
  },
  "voyant": {
    "schema": "./verification/schema",
    "requiresSchemas": [
      "@voyant-travel/db"
    ]
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=storefront_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/bookings": "workspace:^",
    "@voyant-travel/commerce": "workspace:^",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/finance": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/relationships-contracts": "workspace:^",
    "@voyant-travel/utils": "workspace:^",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@voyant-travel/identity": "workspace:^",
    "@voyant-travel/legal": "workspace:^",
    "@voyant-travel/relationships": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@voyant-travel/identity": {
      "optional": true
    },
    "@voyant-travel/legal": {
      "optional": true
    },
    "@voyant-travel/relationships": {
      "optional": true
    }
  },
  "devDependencies": {
    "@voyant-travel/identity": "workspace:^",
    "@voyant-travel/inventory": "workspace:^",
    "@voyant-travel/legal": "workspace:^",
    "@voyant-travel/operations": "workspace:^",
    "@voyant-travel/relationships": "workspace:^",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./admin-routes": {
        "types": "./dist/routes-admin.d.ts",
        "import": "./dist/routes-admin.js",
        "default": "./dist/routes-admin.js"
      },
      "./customer-portal": {
        "types": "./dist/customer-portal/index.d.ts",
        "import": "./dist/customer-portal/index.js",
        "default": "./dist/customer-portal/index.js"
      },
      "./customer-portal/public-routes": {
        "types": "./dist/customer-portal/routes-public.d.ts",
        "import": "./dist/customer-portal/routes-public.js",
        "default": "./dist/customer-portal/routes-public.js"
      },
      "./customer-portal/public-validation": {
        "types": "./dist/customer-portal/validation-public.d.ts",
        "import": "./dist/customer-portal/validation-public.js",
        "default": "./dist/customer-portal/validation-public.js"
      },
      "./customer-portal/routes": {
        "types": "./dist/customer-portal/routes.d.ts",
        "import": "./dist/customer-portal/routes.js",
        "default": "./dist/customer-portal/routes.js"
      },
      "./payment-link": {
        "types": "./dist/payment-link/routes.d.ts",
        "import": "./dist/payment-link/routes.js",
        "default": "./dist/payment-link/routes.js"
      },
      "./public-routes": {
        "types": "./dist/routes-public.d.ts",
        "import": "./dist/routes-public.js",
        "default": "./dist/routes-public.js"
      },
      "./service": {
        "types": "./dist/service.d.ts",
        "import": "./dist/service.js",
        "default": "./dist/service.js"
      },
      "./transport-eligibility": {
        "types": "./dist/transport-eligibility.d.ts",
        "import": "./dist/transport-eligibility.js",
        "default": "./dist/transport-eligibility.js"
      },
      "./validation": {
        "types": "./dist/validation.d.ts",
        "import": "./dist/validation.js",
        "default": "./dist/validation.js"
      },
      "./verification": {
        "types": "./dist/verification/index.d.ts",
        "import": "./dist/verification/index.js",
        "default": "./dist/verification/index.js"
      },
      "./verification/schema": {
        "types": "./dist/verification/schema.d.ts",
        "import": "./dist/verification/schema.js",
        "default": "./dist/verification/schema.js"
      },
      "./verification/public-routes": {
        "types": "./dist/verification/routes-public.d.ts",
        "import": "./dist/verification/routes-public.js",
        "default": "./dist/verification/routes-public.js"
      },
      "./verification/service": {
        "types": "./dist/verification/service.d.ts",
        "import": "./dist/verification/service.js",
        "default": "./dist/verification/service.js"
      },
      "./verification/validation": {
        "types": "./dist/verification/validation.d.ts",
        "import": "./dist/verification/validation.js",
        "default": "./dist/verification/validation.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/storefront"
  }
}
