{
  "name": "@voyant-travel/ui",
  "version": "0.108.11",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ tests/",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extensions": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@voyant-travel/utils": "workspace:^",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.23.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-day-picker": "^9.8.0",
    "react-dom": "^19.2.7",
    "react-easy-crop": "^6.0.2",
    "react-hook-form": "^7.80.0",
    "react-phone-number-input": "^3.4.17",
    "react-resizable-panels": "^3.0.3",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.3.5",
    "vaul": "^1.1.2",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "recharts": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/react": "^16.0.0",
    "@types/node": "catalog:",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.6",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "jsdom": "^29.1.1",
    "postcss-load-config": "^6.0.1",
    "recharts": "3.9.1",
    "tailwindcss": "^4.3.2",
    "typescript": "catalog:"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./styles.css": "./src/styles.css",
    "./postcss.config": "./postcss.config.mjs",
    "./lib/*": "./src/lib/*.ts",
    "./components": "./src/components/index.tsx",
    "./components/*": "./src/components/*.tsx",
    "./components/big-calendar": "./src/components/big-calendar/index.ts",
    "./components/rich-text-variable-extension": "./src/components/rich-text-variable-extension.ts",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "files": [
    "dist",
    "src/styles.css",
    "src/styles",
    "postcss.config.mjs"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      "./globals.css": "./src/styles/globals.css",
      "./styles.css": {
        "default": "./src/styles.css"
      },
      "./postcss.config": "./postcss.config.mjs",
      "./lib/*": {
        "types": "./dist/lib/*.d.ts",
        "import": "./dist/lib/*.js",
        "default": "./dist/lib/*.js"
      },
      "./components": {
        "types": "./dist/components/index.d.ts",
        "import": "./dist/components/index.js",
        "default": "./dist/components/index.js"
      },
      "./components/*": {
        "types": "./dist/components/*.d.ts",
        "import": "./dist/components/*.js",
        "default": "./dist/components/*.js"
      },
      "./components/big-calendar": {
        "types": "./dist/components/big-calendar/index.d.ts",
        "import": "./dist/components/big-calendar/index.js",
        "default": "./dist/components/big-calendar/index.js"
      },
      "./hooks/*": {
        "types": "./dist/hooks/*.d.ts",
        "import": "./dist/hooks/*.js",
        "default": "./dist/hooks/*.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/ui"
  }
}
