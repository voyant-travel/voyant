{
  "openapi": "3.1.0",
  "info": {
    "title": "Distribution Channel Push API",
    "version": "1.0.0"
  },
  "paths": {
    "/v1/admin/distribution/links": {
      "get": {
        "summary": "List channel booking links and status counts",
        "x-voyant-api-id": "@voyant-travel/distribution#channel-push-extension.api",
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "channelId", "in": "query", "schema": { "type": "string" } },
          { "name": "bookingId", "in": "query", "schema": { "type": "string" } },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 500, "default": 50 }
          }
        ],
        "responses": { "200": { "description": "Channel booking links and counts" } }
      }
    },
    "/v1/admin/distribution/retry/{bookingId}": {
      "post": {
        "summary": "Retry channel delivery for a booking",
        "x-voyant-api-id": "@voyant-travel/distribution#channel-push-extension.api",
        "parameters": [
          { "name": "bookingId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "The retry attempt completed" },
          "500": { "description": "The retry attempt failed" }
        }
      }
    },
    "/v1/admin/distribution/deliveries": {
      "get": {
        "summary": "List channel webhook deliveries",
        "x-voyant-api-id": "@voyant-travel/distribution#channel-push-extension.api",
        "parameters": [
          { "name": "bookingId", "in": "query", "schema": { "type": "string" } },
          { "name": "channelId", "in": "query", "schema": { "type": "string" } },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 500, "default": 50 }
          }
        ],
        "responses": { "200": { "description": "Matching webhook deliveries" } }
      }
    },
    "/v1/admin/distribution/throttling": {
      "get": {
        "summary": "Inspect recent per-channel throttling",
        "x-voyant-api-id": "@voyant-travel/distribution#channel-push-extension.api",
        "parameters": [
          {
            "name": "sinceMs",
            "in": "query",
            "schema": { "type": "integer", "minimum": 0, "default": 3600000 }
          }
        ],
        "responses": { "200": { "description": "Per-channel throttling counts" } }
      }
    },
    "/v1/admin/distribution/reconcile/{flow}": {
      "post": {
        "summary": "Run a channel reconciliation flow",
        "x-voyant-api-id": "@voyant-travel/distribution#channel-push-extension.api",
        "parameters": [
          {
            "name": "flow",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "enum": ["bookings", "availability", "content"] }
          }
        ],
        "responses": {
          "200": { "description": "The reconciliation flow completed" },
          "400": { "description": "The flow name is unknown" },
          "500": { "description": "The reconciliation flow failed" }
        }
      }
    }
  }
}
