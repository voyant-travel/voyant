{
  "name": "@voyant-travel/distribution",
  "version": "0.139.1",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./channel-push-workflows": "./src/channel-push/workflow-entry.ts",
    "./external-refs/validation": "./src/external-refs/validation.ts",
    "./suppliers/linkables": "./src/suppliers/linkables.ts",
    "./schema": "./src/schema.ts",
    "./validation": "./src/validation.ts",
    "./routes": "./src/routes.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=distribution_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/bookings": "workspace:^",
    "@voyant-travel/catalog": "workspace:^",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/identity": "workspace:^",
    "@voyant-travel/workflows": "workspace:^",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:",
    "@voyant-travel/suppliers-contracts": "workspace:^"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  },
  "files": [
    "dist",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./channel-push-workflows": {
        "types": "./dist/channel-push/workflow-entry.d.ts",
        "import": "./dist/channel-push/workflow-entry.js",
        "default": "./dist/channel-push/workflow-entry.js"
      },
      "./external-refs/validation": {
        "types": "./dist/external-refs/validation.d.ts",
        "import": "./dist/external-refs/validation.js",
        "default": "./dist/external-refs/validation.js"
      },
      "./suppliers/linkables": {
        "types": "./dist/suppliers/linkables.d.ts",
        "import": "./dist/suppliers/linkables.js",
        "default": "./dist/suppliers/linkables.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./validation": {
        "types": "./dist/validation.d.ts",
        "import": "./dist/validation.js",
        "default": "./dist/validation.js"
      },
      "./routes": {
        "types": "./dist/routes.d.ts",
        "import": "./dist/routes.js",
        "default": "./dist/routes.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/distribution"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node",
        "voyant-cloud"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    },
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/bookings",
      "@voyant-travel/db"
    ]
  }
}
