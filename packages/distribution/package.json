{
  "name": "@voyant-travel/distribution",
  "version": "0.141.5",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./channel-push-subscribers": "./src/channel-push/subscriber-runtime.ts",
    "./channel-push-workflows": "./src/channel-push/workflow-entry.ts",
    "./channel-push-runtime": "./src/channel-push/types.ts",
    "./linkables": "./src/linkables.ts",
    "./schema": "./src/schema.ts",
    "./validation": "./src/validation.ts",
    "./routes": "./src/routes.ts",
    "./payment-policy-runtime": "./src/payment-policy-runtime.ts",
    "./runtime-contributor": "./src/runtime-contributor.ts",
    "./voyant": "./src/voyant.ts",
    "./openapi/admin": "./openapi/admin/distribution.json",
    "./openapi/admin/external-refs": "./openapi/admin/external-refs.json",
    "./openapi/admin/suppliers": "./openapi/admin/suppliers.json",
    "./catalog-runtime-extension": "./src/catalog-runtime-extension.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=distribution_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/bookings": "workspace:^",
    "@voyant-travel/catalog": "workspace:^",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/finance": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/identity": "workspace:^",
    "@voyant-travel/workflows": "workspace:^",
    "@voyant-travel/webhook-delivery": "workspace:^",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:",
    "@voyant-travel/suppliers-contracts": "workspace:^"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  },
  "files": [
    "dist",
    "openapi",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./channel-push-subscribers": {
        "types": "./dist/channel-push/subscriber-runtime.d.ts",
        "import": "./dist/channel-push/subscriber-runtime.js",
        "default": "./dist/channel-push/subscriber-runtime.js"
      },
      "./channel-push-workflows": {
        "types": "./dist/channel-push/workflow-entry.d.ts",
        "import": "./dist/channel-push/workflow-entry.js",
        "default": "./dist/channel-push/workflow-entry.js"
      },
      "./channel-push-runtime": {
        "types": "./dist/channel-push/types.d.ts",
        "import": "./dist/channel-push/types.js",
        "default": "./dist/channel-push/types.js"
      },
      "./linkables": {
        "types": "./dist/linkables.d.ts",
        "import": "./dist/linkables.js",
        "default": "./dist/linkables.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./validation": {
        "types": "./dist/validation.d.ts",
        "import": "./dist/validation.js",
        "default": "./dist/validation.js"
      },
      "./routes": {
        "types": "./dist/routes.d.ts",
        "import": "./dist/routes.js",
        "default": "./dist/routes.js"
      },
      "./payment-policy-runtime": {
        "types": "./dist/payment-policy-runtime.d.ts",
        "import": "./dist/payment-policy-runtime.js",
        "default": "./dist/payment-policy-runtime.js"
      },
      "./runtime-contributor": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      },
      "./openapi/admin": "./openapi/admin/distribution.json",
      "./openapi/admin/external-refs": "./openapi/admin/external-refs.json",
      "./openapi/admin/suppliers": "./openapi/admin/suppliers.json",
      "./catalog-runtime-extension": {
        "types": "./dist/catalog-runtime-extension.d.ts",
        "import": "./dist/catalog-runtime-extension.js",
        "default": "./dist/catalog-runtime-extension.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/distribution"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    },
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/bookings",
      "@voyant-travel/db"
    ],
    "runtime": {
      "entry": "./runtime-contributor",
      "export": "createDistributionRuntimePortContribution"
    }
  }
}
