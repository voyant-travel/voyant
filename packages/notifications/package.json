{
  "name": "@voyant-travel/notifications",
  "version": "0.132.14",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./types": "./src/types.ts",
    "./template-authoring": "./src/template-authoring.ts",
    "./validation": "./src/validation.ts",
    "./routes": "./src/routes.ts",
    "./service": "./src/service.ts",
    "./tasks": "./src/tasks/index.ts",
    "./workflows": "./src/workflow-entry.ts",
    "./workflow-runtime": "./src/workflow-runtime.ts",
    "./runtime-port": "./src/runtime-port.ts",
    "./subscriber-runtime": "./src/subscriber-runtime.ts",
    "./providers/local": "./src/providers/local.ts",
    "./providers/voyant-cloud-email": "./src/providers/voyant-cloud-email.ts",
    "./providers/voyant-cloud-sms": "./src/providers/voyant-cloud-sms.ts",
    "./tools": "./src/mcp-runtime.ts",
    "./runtime-contributor": "./src/runtime-contributor.ts",
    "./voyant": "./src/voyant.ts",
    "./openapi/admin": "./openapi/admin/notifications.json"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=notifications_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/action-ledger": "workspace:^",
    "@voyant-travel/bookings": "workspace:^",
    "@voyant-travel/cloud-sdk": "^0.11.0",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "@voyant-travel/finance": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/storefront": "workspace:^",
    "@voyant-travel/legal": "workspace:^",
    "@voyant-travel/quotes": "workspace:^",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "liquidjs": "^10.27.1",
    "zod": "catalog:",
    "@voyant-travel/tools": "workspace:^",
    "@voyant-travel/workflows": "workspace:^"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "openapi",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./types": {
        "types": "./dist/types.d.ts",
        "import": "./dist/types.js",
        "default": "./dist/types.js"
      },
      "./template-authoring": {
        "types": "./dist/template-authoring.d.ts",
        "import": "./dist/template-authoring.js",
        "default": "./dist/template-authoring.js"
      },
      "./validation": {
        "types": "./dist/validation.d.ts",
        "import": "./dist/validation.js",
        "default": "./dist/validation.js"
      },
      "./routes": {
        "types": "./dist/routes.d.ts",
        "import": "./dist/routes.js",
        "default": "./dist/routes.js"
      },
      "./service": {
        "types": "./dist/service.d.ts",
        "import": "./dist/service.js",
        "default": "./dist/service.js"
      },
      "./tasks": {
        "types": "./dist/tasks/index.d.ts",
        "import": "./dist/tasks/index.js",
        "default": "./dist/tasks/index.js"
      },
      "./workflows": {
        "types": "./dist/workflow-entry.d.ts",
        "import": "./dist/workflow-entry.js",
        "default": "./dist/workflow-entry.js"
      },
      "./workflow-runtime": {
        "types": "./dist/workflow-runtime.d.ts",
        "import": "./dist/workflow-runtime.js",
        "default": "./dist/workflow-runtime.js"
      },
      "./runtime-port": {
        "types": "./dist/runtime-port.d.ts",
        "import": "./dist/runtime-port.js",
        "default": "./dist/runtime-port.js"
      },
      "./subscriber-runtime": {
        "types": "./dist/subscriber-runtime.d.ts",
        "import": "./dist/subscriber-runtime.js",
        "default": "./dist/subscriber-runtime.js"
      },
      "./providers/local": {
        "types": "./dist/providers/local.d.ts",
        "import": "./dist/providers/local.js",
        "default": "./dist/providers/local.js"
      },
      "./providers/voyant-cloud-email": {
        "types": "./dist/providers/voyant-cloud-email.d.ts",
        "import": "./dist/providers/voyant-cloud-email.js",
        "default": "./dist/providers/voyant-cloud-email.js"
      },
      "./providers/voyant-cloud-sms": {
        "types": "./dist/providers/voyant-cloud-sms.d.ts",
        "import": "./dist/providers/voyant-cloud-sms.js",
        "default": "./dist/providers/voyant-cloud-sms.js"
      },
      "./tools": {
        "types": "./dist/mcp-runtime.d.ts",
        "import": "./dist/mcp-runtime.js",
        "default": "./dist/mcp-runtime.js"
      },
      "./runtime-contributor": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      },
      "./openapi/admin": "./openapi/admin/notifications.json"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/notifications"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "runtime": {
      "entry": "./runtime-contributor",
      "export": "createNotificationsRuntimePortContribution"
    },
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    },
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/db"
    ]
  }
}
