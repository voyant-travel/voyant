{
  "name": "@voyant-travel/action-ledger",
  "version": "0.108.4",
  "description": "Action ledger schema, append-only write helpers, and idempotency primitives for Voyant control surfaces.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./canary": "./src/canary.ts",
    "./capability": "./src/capability.ts",
    "./schema": "./src/schema.ts",
    "./service": "./src/service.ts",
    "./fingerprint": "./src/fingerprint.ts",
    "./health": "./src/health-routes.ts",
    "./graph-runtime": "./src/graph-runtime.ts",
    "./runtime-port": "./src/runtime-port.ts",
    "./timeline": "./src/timeline.ts",
    "./request-context": "./src/request-context.ts",
    "./routes": "./src/routes.ts",
    "./voyant": "./src/voyant.ts",
    "./openapi/admin": "./openapi/admin/action-ledger.json",
    "./openapi/admin/health": "./openapi/admin/action-ledger-health.json"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/ tests/",
    "test": "vitest run --passWithNoTests",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=action_ledger_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "openapi",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./canary": {
        "types": "./dist/canary.d.ts",
        "import": "./dist/canary.js",
        "default": "./dist/canary.js"
      },
      "./capability": {
        "types": "./dist/capability.d.ts",
        "import": "./dist/capability.js",
        "default": "./dist/capability.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./service": {
        "types": "./dist/service.d.ts",
        "import": "./dist/service.js",
        "default": "./dist/service.js"
      },
      "./fingerprint": {
        "types": "./dist/fingerprint.d.ts",
        "import": "./dist/fingerprint.js",
        "default": "./dist/fingerprint.js"
      },
      "./health": {
        "types": "./dist/health-routes.d.ts",
        "import": "./dist/health-routes.js",
        "default": "./dist/health-routes.js"
      },
      "./timeline": {
        "types": "./dist/timeline.d.ts",
        "import": "./dist/timeline.js",
        "default": "./dist/timeline.js"
      },
      "./request-context": {
        "types": "./dist/request-context.d.ts",
        "import": "./dist/request-context.js",
        "default": "./dist/request-context.js"
      },
      "./routes": {
        "types": "./dist/routes.d.ts",
        "import": "./dist/routes.js",
        "default": "./dist/routes.js"
      },
      "./graph-runtime": {
        "types": "./dist/graph-runtime.d.ts",
        "import": "./dist/graph-runtime.js",
        "default": "./dist/graph-runtime.js"
      },
      "./runtime-port": {
        "types": "./dist/runtime-port.d.ts",
        "import": "./dist/runtime-port.js",
        "default": "./dist/runtime-port.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      },
      "./openapi/admin": "./openapi/admin/action-ledger.json",
      "./openapi/admin/health": "./openapi/admin/action-ledger-health.json"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/action-ledger"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    },
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/db"
    ]
  }
}
