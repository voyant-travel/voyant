{
  "name": "@voyantjs/admin-app",
  "version": "0.10.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./root": "./src/root.tsx",
    "./router": "./src/router.tsx",
    "./workspace": "./src/workspace.tsx",
    "./core-extension": "./src/core-extension/index.tsx"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ tests/",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-router": "^1.0.0",
    "@voyantjs/admin": "workspace:^",
    "@voyantjs/auth-react": "workspace:^",
    "@voyantjs/commerce-react": "workspace:^",
    "@voyantjs/distribution-react": "workspace:^",
    "@voyantjs/finance-react": "workspace:^",
    "@voyantjs/inventory-react": "workspace:^",
    "@voyantjs/ui": "workspace:^",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-router": "^1.170.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@voyantjs/admin": "workspace:^",
    "@voyantjs/auth-react": "workspace:^",
    "@voyantjs/commerce-react": "workspace:^",
    "@voyantjs/distribution-react": "workspace:^",
    "@voyantjs/finance-react": "workspace:^",
    "@voyantjs/inventory-react": "workspace:^",
    "@voyantjs/ui": "workspace:^",
    "@voyantjs/voyant-typescript-config": "workspace:^",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./root": {
        "types": "./dist/root.d.ts",
        "import": "./dist/root.js",
        "default": "./dist/root.js"
      },
      "./router": {
        "types": "./dist/router.d.ts",
        "import": "./dist/router.js",
        "default": "./dist/router.js"
      },
      "./workspace": {
        "types": "./dist/workspace.d.ts",
        "import": "./dist/workspace.js",
        "default": "./dist/workspace.js"
      },
      "./core-extension": {
        "types": "./dist/core-extension/index.d.ts",
        "import": "./dist/core-extension/index.js",
        "default": "./dist/core-extension/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/admin-app"
  },
  "peerDependenciesMeta": {
    "@voyantjs/auth-react": {
      "optional": true
    },
    "@voyantjs/commerce-react": {
      "optional": true
    },
    "@voyantjs/distribution-react": {
      "optional": true
    },
    "@voyantjs/finance-react": {
      "optional": true
    },
    "@voyantjs/inventory-react": {
      "optional": true
    }
  }
}
