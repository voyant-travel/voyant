{
  "name": "@voyant-travel/admin-app",
  "version": "0.85.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./root": "./src/root.tsx",
    "./router": "./src/router.tsx",
    "./workspace": "./src/workspace.tsx",
    "./extension-routes": "./src/extension-routes.tsx",
    "./core-extension": "./src/core-extension/index.tsx",
    "./runtime": "./src/runtime.ts"
  },
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig*.tsbuildinfo",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/ tests/",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-router": "^1.0.0",
    "@tanstack/react-start": "^1.168.27",
    "@voyant-travel/admin": "workspace:^",
    "@voyant-travel/auth-react": "workspace:^",
    "@voyant-travel/commerce-react": "workspace:^",
    "@voyant-travel/distribution-react": "workspace:^",
    "@voyant-travel/finance-react": "workspace:^",
    "@voyant-travel/inventory-react": "workspace:^",
    "@voyant-travel/react": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "@voyant-travel/ui": "workspace:^",
    "lucide-react": "^0.475.0 || ^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "@types/node": "catalog:",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@voyant-travel/admin": "workspace:^",
    "@voyant-travel/auth-react": "workspace:^",
    "@voyant-travel/commerce-react": "workspace:^",
    "@voyant-travel/distribution-react": "workspace:^",
    "@voyant-travel/finance-react": "workspace:^",
    "@voyant-travel/inventory-react": "workspace:^",
    "@voyant-travel/react": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "@voyant-travel/ui": "workspace:^",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./root": {
        "types": "./dist/root.d.ts",
        "import": "./dist/root.js",
        "default": "./dist/root.js"
      },
      "./router": {
        "types": "./dist/router.d.ts",
        "import": "./dist/router.js",
        "default": "./dist/router.js"
      },
      "./workspace": {
        "types": "./dist/workspace.d.ts",
        "import": "./dist/workspace.js",
        "default": "./dist/workspace.js"
      },
      "./extension-routes": {
        "types": "./dist/extension-routes.d.ts",
        "import": "./dist/extension-routes.js",
        "default": "./dist/extension-routes.js"
      },
      "./core-extension": {
        "types": "./dist/core-extension/index.d.ts",
        "import": "./dist/core-extension/index.js",
        "default": "./dist/core-extension/index.js"
      },
      "./runtime": {
        "types": "./dist/runtime.d.ts",
        "import": "./dist/runtime.js",
        "default": "./dist/runtime.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/admin-app"
  },
  "peerDependenciesMeta": {
    "@voyant-travel/auth-react": {
      "optional": true
    },
    "@voyant-travel/commerce-react": {
      "optional": true
    },
    "@voyant-travel/distribution-react": {
      "optional": true
    },
    "@voyant-travel/finance-react": {
      "optional": true
    },
    "@voyant-travel/inventory-react": {
      "optional": true
    }
  }
}
