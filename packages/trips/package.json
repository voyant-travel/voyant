{
  "name": "@voyant-travel/trips",
  "version": "0.145.0",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./validation": "./src/validation.ts",
    "./service": "./src/service.ts",
    "./tools": "./src/mcp-runtime.ts",
    "./checkout": "./src/checkout/index.ts",
    "./catalog-component": "./src/catalog-component.ts",
    "./flight-component": "./src/flight-component.ts",
    "./route-runtime": "./src/route-runtime.ts",
    "./cruise-extension": "./src/cruise-extension.ts",
    "./payment-subscribers": "./src/payment-subscriber-runtime.ts",
    "./routes": "./src/routes.ts",
    "./runtime-contributor": "./src/runtime-contributor.ts",
    "./voyant": "./src/voyant.ts",
    "./openapi/admin": "./openapi/admin/trips.json",
    "./openapi/storefront": "./openapi/storefront/trips.json"
  },
  "voyant": {
    "schemaVersion": "voyant.package.v1",
    "kind": "module",
    "manifest": "./voyant",
    "runtime": {
      "entry": "./runtime-contributor",
      "export": "createTripsRuntimePortContribution"
    },
    "compatibleWith": {
      "framework": ">=0.26.0",
      "targets": [
        "node"
      ],
      "modes": [
        "local",
        "managed-cloud",
        "self-hosted"
      ]
    },
    "schema": "./schema",
    "requiresSchemas": [
      "@voyant-travel/db"
    ]
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/ tests/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build",
    "db:generate": "drizzle-kit generate --config=drizzle.migrations.config.ts --name=trips_baseline && node ../../scripts/migrations/guard-create-type.mjs ./migrations && node ../../scripts/migrations/ensure-extensions.mjs ./migrations"
  },
  "dependencies": {
    "@hono/zod-openapi": "catalog:",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/bookings": "workspace:^",
    "@voyant-travel/catalog": "workspace:^",
    "@voyant-travel/commerce": "workspace:^",
    "@voyant-travel/catalog-contracts": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/finance": "workspace:^",
    "@voyant-travel/flights": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/inventory": "workspace:^",
    "@voyant-travel/operator-settings": "workspace:^",
    "@voyant-travel/plugin-netopia": "^0.105.21",
    "@voyant-travel/storefront": "workspace:^",
    "@voyant-travel/tools": "workspace:^",
    "@voyant-travel/types": "workspace:^",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "openapi",
    "migrations/*.sql",
    "migrations/meta/_journal.json"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js",
        "default": "./dist/schema.js"
      },
      "./validation": {
        "types": "./dist/validation.d.ts",
        "import": "./dist/validation.js",
        "default": "./dist/validation.js"
      },
      "./service": {
        "types": "./dist/service.d.ts",
        "import": "./dist/service.js",
        "default": "./dist/service.js"
      },
      "./tools": {
        "types": "./dist/mcp-runtime.d.ts",
        "import": "./dist/mcp-runtime.js",
        "default": "./dist/mcp-runtime.js"
      },
      "./checkout": {
        "types": "./dist/checkout/index.d.ts",
        "import": "./dist/checkout/index.js",
        "default": "./dist/checkout/index.js"
      },
      "./catalog-component": {
        "types": "./dist/catalog-component.d.ts",
        "import": "./dist/catalog-component.js",
        "default": "./dist/catalog-component.js"
      },
      "./flight-component": {
        "types": "./dist/flight-component.d.ts",
        "import": "./dist/flight-component.js",
        "default": "./dist/flight-component.js"
      },
      "./route-runtime": {
        "types": "./dist/route-runtime.d.ts",
        "import": "./dist/route-runtime.js",
        "default": "./dist/route-runtime.js"
      },
      "./cruise-extension": {
        "types": "./dist/cruise-extension.d.ts",
        "import": "./dist/cruise-extension.js",
        "default": "./dist/cruise-extension.js"
      },
      "./payment-subscribers": {
        "types": "./dist/payment-subscriber-runtime.d.ts",
        "import": "./dist/payment-subscriber-runtime.js",
        "default": "./dist/payment-subscriber-runtime.js"
      },
      "./routes": {
        "types": "./dist/routes.d.ts",
        "import": "./dist/routes.js",
        "default": "./dist/routes.js"
      },
      "./runtime-contributor": {
        "types": "./dist/runtime-contributor.d.ts",
        "import": "./dist/runtime-contributor.js",
        "default": "./dist/runtime-contributor.js"
      },
      "./voyant": {
        "types": "./dist/voyant.d.ts",
        "import": "./dist/voyant.js",
        "default": "./dist/voyant.js"
      },
      "./openapi/admin": "./openapi/admin/trips.json",
      "./openapi/storefront": "./openapi/storefront/trips.json"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/trips"
  }
}
