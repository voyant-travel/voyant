{
  "name": "@voyantjs/catalog-mcp",
  "version": "0.59.0",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./contract": "./src/contract.ts",
    "./registry": "./src/registry.ts",
    "./tools/search-catalog": "./src/tools/search-catalog.ts",
    "./tools/get-entity": "./src/tools/get-entity.ts",
    "./tools/suggest-alternatives": "./src/tools/suggest-alternatives.ts",
    "./tools/check-availability": "./src/tools/check-availability.ts",
    "./tools/get-quote": "./src/tools/get-quote.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm run build"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./contract": {
        "types": "./dist/contract.d.ts",
        "import": "./dist/contract.js",
        "default": "./dist/contract.js"
      },
      "./registry": {
        "types": "./dist/registry.d.ts",
        "import": "./dist/registry.js",
        "default": "./dist/registry.js"
      },
      "./tools/search-catalog": {
        "types": "./dist/tools/search-catalog.d.ts",
        "import": "./dist/tools/search-catalog.js",
        "default": "./dist/tools/search-catalog.js"
      },
      "./tools/get-entity": {
        "types": "./dist/tools/get-entity.d.ts",
        "import": "./dist/tools/get-entity.js",
        "default": "./dist/tools/get-entity.js"
      },
      "./tools/suggest-alternatives": {
        "types": "./dist/tools/suggest-alternatives.d.ts",
        "import": "./dist/tools/suggest-alternatives.js",
        "default": "./dist/tools/suggest-alternatives.js"
      },
      "./tools/check-availability": {
        "types": "./dist/tools/check-availability.d.ts",
        "import": "./dist/tools/check-availability.js",
        "default": "./dist/tools/check-availability.js"
      },
      "./tools/get-quote": {
        "types": "./dist/tools/get-quote.d.ts",
        "import": "./dist/tools/get-quote.js",
        "default": "./dist/tools/get-quote.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "dependencies": {
    "@voyantjs/catalog": "workspace:*",
    "@voyantjs/catalog-rag": "workspace:*",
    "zod": "^4.1.4"
  },
  "devDependencies": {
    "@voyantjs/voyant-typescript-config": "workspace:*",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyantjs/voyant.git",
    "directory": "packages/catalog-mcp"
  }
}
