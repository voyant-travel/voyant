{
  "name": "@voyant-travel/event-catalog-react",
  "version": "0.9.0",
  "description": "Admin event contract reference for selected Voyant deployments.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./admin": "./src/admin.tsx",
    "./i18n": "./src/i18n.tsx"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check src/ tests/",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@voyant-travel/admin": "workspace:^",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/react": "workspace:^",
    "lucide-react": "^0.475.0 || ^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@voyant-travel/i18n": "workspace:^"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@voyant-travel/admin": "workspace:^",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/react": "workspace:^",
    "@voyant-travel/voyant-typescript-config": "workspace:^",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./admin": {
        "types": "./dist/admin.d.ts",
        "import": "./dist/admin.js",
        "default": "./dist/admin.js"
      },
      "./i18n": {
        "types": "./dist/i18n.d.ts",
        "import": "./dist/i18n.js",
        "default": "./dist/i18n.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voyant-travel/voyant.git",
    "directory": "packages/event-catalog-react"
  }
}
