{
  "$schema": "https://json.schemastore.org/eslintrc",
  "overrides": [
    {
      "files": ["**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "@voyant-travel/db/src",
                "message": "Import from @voyant-travel/db/schema/* or @voyant-travel/db/* public exports instead of /src"
              },
              {
                "name": "@voyant-travel/db/src/schema",
                "message": "Use @voyant-travel/db/schema/* public subpath exports"
              }
            ],
            "patterns": [
              {
                "group": ["@voyant-travel/db/src/*"],
                "message": "Use @voyant-travel/db/* public exports"
              },
              {
                "group": ["@voyant-travel/db/src/schema/*"],
                "message": "Use @voyant-travel/db/schema/* public subpath exports"
              }
            ]
          }
        ]
      }
    }
  ]
}
