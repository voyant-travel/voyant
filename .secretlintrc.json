{
  "$schema": "https://raw.githubusercontent.com/secretlint/secretlint/main/packages/%40secretlint/config-loader/secretlint-schema.json",
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-preset-recommend",
      "rules": [
        {
          "id": "@secretlint/secretlint-rule-database-connection-string",
          "options": {
            "allows": ["/postgresql:\\/\\/[^@]+@(localhost|127\\.0\\.0\\.1)(:\\d+)?\\/[\\w-]+/"]
          }
        }
      ]
    }
  ]
}
