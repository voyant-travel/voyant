{
  "name": "federated-operator",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3310",
    "build": "vite build",
    "preview": "pnpm run build && vite preview",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=8192 tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "deploy": "pnpm run build && wrangler deploy",
    "db:generate": "drizzle-kit generate --config=drizzle.deployment-migrations.config.ts",
    "db:generate:deployment": "drizzle-kit generate --config=drizzle.deployment-migrations.config.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "lint": "biome check src/ --css-parse-tailwind-directives=true"
  },
  "dependencies": {
    "@better-auth/api-key": "1.6.23",
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@hono/zod-openapi": "catalog:",
    "@neondatabase/serverless": "^1.1.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "@voyant-travel/action-ledger": "workspace:^",
    "@voyant-travel/action-ledger-react": "workspace:^",
    "@voyant-travel/admin": "workspace:^",
    "@voyant-travel/auth": "workspace:^",
    "@voyant-travel/auth-react": "workspace:^",
    "@voyant-travel/core": "workspace:^",
    "@voyant-travel/db": "workspace:^",
    "@voyant-travel/hono": "workspace:^",
    "@voyant-travel/identity": "workspace:^",
    "@voyant-travel/react": "workspace:^",
    "@voyant-travel/relationships": "workspace:^",
    "@voyant-travel/relationships-react": "workspace:^",
    "@voyant-travel/ui": "workspace:^",
    "@voyant-travel/worker-runtime": "workspace:^",
    "@voyant-travel/workflow-runs": "workspace:^",
    "@voyant-travel/workflows-react": "workspace:^",
    "better-auth": "1.6.23",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "immer": "^11.1.11",
    "lucide-react": "^1.23.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zod": "catalog:",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "@cloudflare/workers-types": "catalog:",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/devtools-vite": "^0.8.1",
    "@types/node": "catalog:",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@voyant-travel/cli": "^0.32.2",
    "@voyant-travel/framework-migrations": "workspace:^",
