# Copy to `.dev.vars` and fill in values. Never commit `.dev.vars`.

DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

BETTER_AUTH_SECRET="<generate with: openssl rand -base64 32>"
SESSION_CLAIMS_SECRET="<generate with: openssl rand -base64 32>"
INTERNAL_API_KEY="<generate with: openssl rand -hex 32>"

API_BASE_URL="http://localhost:3310/api"
CORS_ALLOWLIST="http://localhost:3310"

# Local KMS is enough for development. Person-document reveal routes return
# 503 until KMS_LOCAL_KEY is configured.
KMS_PROVIDER="local"
KMS_LOCAL_KEY="<generate with: openssl rand -base64 32>"

# Optional: show auth OTP/reset fallbacks in the dev console.
VOYANT_AUTH_LOG_SECRET_FALLBACKS="1"
