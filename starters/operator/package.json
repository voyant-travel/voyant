{
  "name": "operator",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run graph:emit && pnpm run graph:env && node -r ./scripts/env-preload.cjs node_modules/vite/bin/vite.js dev --port 3300",
    "build": "pnpm run graph:emit && vite build && pnpm run copy:deployment-artifacts",
    "copy:deployment-artifacts": "rm -rf dist/.voyant dist/server/.voyant && mkdir -p dist/server && cp -R .voyant dist/.voyant && cp -R .voyant dist/server/.voyant",
    "preview": "pnpm run build && vite preview",
    "measure": "node ../../scripts/measure-standard-node-starter.mjs --require-build",
    "start": "node -r ./scripts/env-preload.cjs dist/server/server.js",
    "typecheck": "pnpm run graph:emit && NODE_OPTIONS=--max-old-space-size=14336 tsc -p tsconfig.server.json && NODE_OPTIONS=--max-old-space-size=14336 tsc -p tsconfig.client.json",
    "test": "pnpm run graph:emit && vitest run --passWithNoTests",
    "generate:openapi": "pnpm run graph:emit && UPDATE_OPENAPI=1 vitest run src/api/openapi.test.ts",
    "graph:check": "tsx ../../scripts/emit-deployment-graph.ts",
    "graph:env": "tsx scripts/check-deployment-graph-env.ts",
    "graph:emit": "tsx ../../scripts/emit-deployment-graph.ts --emit",
    "dev:worker": "voyant dev --file src/workflow-runtime.ts --port 3310",
    "emit:cloud-scheduler": "pnpm run graph:emit && tsx scripts/emit-cloud-scheduler.ts",
    "workflows:build": "voyant workflows build --file src/workflow-runtime.ts --out dist/workflows",
    "workflows:doctor": "voyant workflows doctor --target entry --file src/workflow-runtime.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.deployment-migrations.config.ts",
    "db:generate:deployment": "drizzle-kit generate --config=drizzle.deployment-migrations.config.ts",
    "db:migrate": "pnpm run graph:emit && tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check --config=drizzle.deployment-migrations.config.ts",
    "db:studio": "drizzle-kit studio",
    "reindex": "tsx scripts/reindex.ts",
    "seed": "tsx scripts/seed.ts",
    "sync:sources": "tsx scripts/sync-sources.ts",
    "lint": "biome check src/"
  },
