            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "bookingId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "stayBookingItemId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "checkIn": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                  },
                  "checkOut": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                  },
                  "rooms": {
                    "type": "integer",
                    "minimum": 1,
                    "default": 1
