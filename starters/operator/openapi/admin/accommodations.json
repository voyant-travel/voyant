            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nights": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "date": {
                          "type": "string",
                          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                        },
                        "roomsHeld": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "netRateCentsOverride": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "sellRateCentsOverride": {
                          "type": "integer",
                          "minimum": 0
                        }
                      },
                      "required": [
                        "date",
                        "roomsHeld"
                      ]
                    },
                    "minItems": 1
                  }
                },
                "required": [
                  "nights"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The recomputed block summary after the nights upsert",
