            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "pickupId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "stayBookingItemId": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The reversed pickup ledger row",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "blockId": {
                          "type": "string"
                        },
                        "bookingId": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "stayBookingItemId": {
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "checkIn": {
                          "type": "string"
                        },
                        "checkOut": {
                          "type": "string"
                        },
                        "rooms": {
                          "type": "integer"
                        },
                        "status": {
                          "type": "string",
                          "enum": [
                            "active",
                            "reversed"
                          ]
                        },
                        "pickedUpAt": {
                          "type": "string"
                        },
                        "reversedAt": {
                          "type": [
                            "string",
                            "null"
                          ]
                        }
                      },
                      "required": [
                        "id",
                        "blockId",
                        "bookingId",
                        "stayBookingItemId",
                        "checkIn",
                        "checkOut",
                        "rooms",
                        "status",
                        "pickedUpAt",
                        "reversedAt"
