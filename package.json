{
  "name": "voyant",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "biome check .",
    "lint:changed": "node scripts/lint-changed.mjs",
    "lint:workspace": "turbo run lint --continue --output-logs=new-only",
    "lint:fix": "biome check --write .",
    "format": "biome check --write .",
    "changeset": "changeset",
    "version-packages": "node scripts/version-packages.cjs",
    "release": "changeset publish",
    "release:plan": "node scripts/release-plan.cjs",
    "publish:voyant-travel": "node scripts/publish-voyant-travel-workspace.mjs",
    "verify:release-config": "node scripts/verify-release-config.cjs",
    "package:starters": "node scripts/package-starters.mjs",
    "generate:schema-docs": "tsx scripts/generate-schema-docs.ts",
    "i18n:check": "pnpm i18n:check:admin && pnpm i18n:check:packages && pnpm i18n:check:ui-literals",
    "i18n:check:admin": "node --import tsx scripts/check-i18n-parity.ts",
    "i18n:check:packages": "node --import tsx scripts/check-package-i18n-parity.mjs",
    "i18n:check:ui-literals": "node --test scripts/tests/check-ui-hardcoded-strings.test.mjs && node --import tsx scripts/check-ui-hardcoded-strings.mjs",
    "verify:package-exports": "tsx scripts/verify-package-exports.ts",
    "verify:ui-components-barrel": "node scripts/check-ui-components-barrel.mjs",
    "verify:ui-orientation-selectors": "node scripts/check-ui-orientation-selectors.mjs",
    "verify:date-picker-single-source": "node scripts/check-date-picker-single-source.mjs",
    "verify:publish-tarballs": "node scripts/verify-package-tarballs.mjs",
    "verify:tenant-scoping": "node scripts/check-tenant-scoping.mjs",
    "verify:route-authoring": "node scripts/check-route-authoring.mjs",
    "verify:route-ownership": "node scripts/check-route-ownership.mjs",
    "verify:public-cache-policy": "node scripts/check-public-cache-policy.mjs",
    "verify:node-entrypoint": "node scripts/check-node-entrypoint.mjs",
    "verify:client-package-boundaries": "node scripts/check-client-package-boundaries.mjs",
    "verify:workflows-package-surface": "node scripts/check-workflows-package-surface.mjs",
    "verify:accommodation-resale-boundary": "node scripts/check-accommodation-resale-boundary.mjs",
    "verify:retail-spine-closure": "node scripts/check-retail-spine-closure.mjs",
    "verify:v1-package-cleanup": "tsx scripts/check-v1-package-cleanup.ts",
    "verify:v1-package-cleanup:strict": "tsx scripts/check-v1-package-cleanup.ts --fail-on-temporary",
    "verify:native-date-inputs": "node scripts/check-native-date-inputs.mjs",
    "verify:raw-minor-unit-labels": "node scripts/check-raw-minor-unit-labels.mjs",
    "verify:lockstep-membership": "node scripts/check-lockstep-membership.mjs",
    "verify:admin-composition-drift": "node scripts/check-admin-composition-drift.mjs",
    "verify:framework-bom": "node scripts/generate-framework-bom.mjs",
    "verify:framework-migration-bundle": "node scripts/generate-framework-migration-bundle.mjs",
    "verify:migration-replay-parity": "node scripts/verify-migration-replay-parity.mjs",
    "verify:architecture": "pnpm verify:tenant-scoping && pnpm verify:route-authoring && pnpm verify:public-cache-policy && pnpm verify:node-entrypoint && pnpm verify:client-package-boundaries && pnpm verify:workflows-package-surface && pnpm verify:accommodation-resale-boundary && pnpm verify:retail-spine-closure && pnpm verify:migration-boundaries && pnpm verify:migration-cutline && pnpm verify:v1-package-cleanup && pnpm verify:lockstep-membership && pnpm verify:admin-composition-drift && pnpm verify:framework-bom && pnpm verify:migration-replay-parity && pnpm verify:dep-paths && pnpm verify:dist-configs && pnpm verify:dependency-versions",
    "verify:agent-quality": "node scripts/check-agent-code-quality.mjs",
    "verify:agent-quality:changed": "node scripts/check-agent-code-quality.mjs --changed",
    "verify:fast": "pnpm lint:changed && pnpm verify:agent-quality:changed && pnpm verify:date-picker-single-source && pnpm verify:ui-components-barrel && pnpm verify:ui-orientation-selectors && pnpm verify:native-date-inputs && pnpm verify:raw-minor-unit-labels && pnpm typecheck:affected && pnpm test:affected && pnpm verify:architecture",
    "verify:full": "pnpm lint && pnpm verify:agent-quality && pnpm verify:date-picker-single-source && pnpm verify:ui-components-barrel && pnpm verify:ui-orientation-selectors && pnpm verify:native-date-inputs && pnpm verify:raw-minor-unit-labels && pnpm typecheck && pnpm test && pnpm verify:architecture && pnpm verify:release-config && pnpm build && pnpm verify:package-exports && pnpm verify:publish-tarballs && pnpm i18n:check",
    "prepare": "husky",
    "seed:operator": "pnpm -C apps/scripts seed:operator",
    "regen:routes": "tsx scripts/regen-route-tree.ts",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=8192 turbo run typecheck --continue",
    "typecheck:affected": "turbo run typecheck --affected --continue --output-logs=new-only",
    "test": "node scripts/run-tests.cjs",
    "test:affected": "turbo run test --affected --continue --output-logs=new-only",
    "test:bookings:integration": "node scripts/run-bookings-integration-tests.mjs",
    "verify:dependency-versions": "node scripts/check-dependency-versions.mjs",
    "deps:outdated": "pnpm -r outdated",
    "deps:unused": "pnpm -r exec npx --yes depcheck --json || true",
    "db:build": "turbo run build --filter=\"@voyant-travel/db\"",
    "db:generate": "pnpm -C starters/operator db:generate",
    "db:migrate": "pnpm -C starters/operator db:migrate",
    "db:check": "pnpm -C starters/operator db:check",
    "db:studio": "pnpm -C starters/operator db:studio",
    "action-ledger:booking-drift:plan": "tsx scripts/action-ledger-booking-drift-plan.ts",
    "tb:deploy": "cd tinybird && tb --cloud deploy",
    "verify:migration-boundaries": "node scripts/migrations/lint-package-boundaries.mjs",
    "verify:migration-cutline": "node scripts/migrations/generate-cutline.mjs",
    "generate:dep-paths": "node scripts/gen-composition-dep-paths.mjs",
    "verify:dep-paths": "node scripts/check-composition-dep-paths.mjs",
    "generate:dist-configs": "node scripts/gen-package-dist-configs.mjs",
    "verify:dist-configs": "node scripts/check-package-dist-configs.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@changesets/apply-release-plan": "^7.1.1",
    "@changesets/assemble-release-plan": "^6.0.10",
    "@changesets/cli": "^2.31.0",
    "@changesets/config": "^3.1.4",
    "@changesets/get-release-plan": "^4.0.16",
    "@changesets/pre": "^2.0.2",
    "@changesets/read": "^0.6.7",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@manypkg/get-packages": "^1.1.3",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "depcheck": "^1.4.7",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "1.61.1",
    "secretlint": "^13.0.2",
    "semver": "^7.8.5",
    "tsx": "catalog:",
    "turbo": "^2.10.3",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "playwright",
      "unrs-resolver",
      "@tailwindcss/oxide",
      "core-js-pure",
      "protobufjs"
    ],
    "overrides": {
      "@vercel/node>typescript": "^5.9.0",
      "@vercel/node>ts-node": "10.9.2",
      "@prisma/instrumentation>@opentelemetry/instrumentation": "0.204.0",
      "import-in-the-middle": "1.15.0",
      "require-in-the-middle": "7.5.2",
      "axios": ">=1.16.0",
      "next": "15.5.18",
      "hono": "4.12.25",
      "@hono/node-server": "2.0.6",
      "shell-quote": "1.8.4",
      "fast-uri": "3.1.2",
      "postcss": "8.5.15",
      "qs": "6.15.2",
      "ws": "8.20.1",
      "express-rate-limit": "8.5.2",
      "esbuild": "0.28.1",
      "uuid": "11.1.1",
      "minimatch@10.2.5>brace-expansion": "5.0.6",
      "yaml": "2.8.3"
    }
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "**/*": [
      "secretlint"
    ]
  },
  "dependencies": {}
}
